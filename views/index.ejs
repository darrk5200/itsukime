                <!DOCTYPE html>
                <html lang="en">
                <head>
                    <meta charset="UTF-8">
                    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
                    <meta name="title" content="Itsukime">
                    <meta name="description" content="Anime streaming site established in order to stop piracy.">
                    <meta property="og:type" content="website">
                    <meta property="og:url" content="https://itsukime.space/">
                    <meta property="og:title" content="Itsukime">
                    <meta property="og:description" content="Anime streaming site established in order to stop piracy">
                    <meta property="og:image" content="https://media.tenor.com/ABkcBqwf1ZgAAAAe/the-quintessential-quintuplets-nanako.png">
                    <meta property="og:site_name" content="Itsukime">
                    <meta property="og:locale" content="en_US">
                    <link rel="icon" type="image/png" sizes="32x32" href="https://media.tenor.com/ABkcBqwf1ZgAAAAe/the-quintessential-quintuplets-nanako.png">
                    <link rel="icon" type="image/png" sizes="16x16" href="https://media.tenor.com/ABkcBqwf1ZgAAAAe/the-quintessential-quintuplets-nanako.png">
                    <link rel="shortcut icon" href="https://media.tenor.com/ABkcBqwf1ZgAAAAe/the-quintessential-quintuplets-nanako.png">
                    <link rel="apple-touch-icon" sizes="180x180" href="https://media.tenor.com/ABkcBqwf1ZgAAAAe/the-quintessential-quintuplets-nanako.png">
                    <title>Itsukime</title>
                    <script>
                        (function() {
                            var t = localStorage.getItem('itsukime_theme');
                            if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
                        })();
                    </script>
                    <script src="https://cdn.socket.io/4.6.1/socket.io.min.js"></script>
                    <link rel="preconnect" href="https://fonts.googleapis.com">
                    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
                    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
                    <style>
                        :root {
                            --bg-primary: #0a0a0a;
                            --bg-secondary: #141414;
                            --bg-card: #1a1a1a;
                            --bg-player: #0d0d0d;
                            --text-primary: #ffffff;
                            --text-secondary: #cccccc;
                            --text-muted: #999999;
                            --text-dim: #666666;
                            --accent: #8b0000;
                            --accent-bright: #e81c1c;
                            --accent-soft: #ff9999;
                            --accent-glow: rgba(139,0,0,0.35);
                            --border-color: #2a2a2a;
                            --border-accent: #8b0000;
                            --footer-bg: #0a0a0a;
                            --input-bg: rgba(20,20,20,0.95);
                            --dropdown-bg: #181818;
                            --scrollbar-track: #141414;
                            --radial-glow: rgba(139,0,0,0.1);
                        }

                        [data-theme="light"] {
                            --bg-primary: #f4f4f6;
                            --bg-secondary: #ffffff;
                            --bg-card: #ffffff;
                            --bg-player: #f0f0f2;
                            --text-primary: #111111;
                            --text-secondary: #333333;
                            --text-muted: #555555;
                            --text-dim: #888888;
                            --accent: #FA4343;
                            --accent-bright: #e02020;
                            --accent-soft: #FA4343;
                            --accent-glow: rgba(250,67,67,0.2);
                            --border-color: #e4e4e4;
                            --border-accent: #FA4343;
                            --footer-bg: #ffffff;
                            --input-bg: #ffffff;
                            --dropdown-bg: #ffffff;
                            --scrollbar-track: #e8e8e8;
                            --radial-glow: rgba(250,67,67,0.06);
                        }

                        * {
                            margin: 0;
                            padding: 0;
                            box-sizing: border-box;
                            font-family: 'Inter', 'Segoe UI', sans-serif;
                            -webkit-tap-highlight-color: transparent;
                        }

                        button, [role="button"] {
                            outline: none;
                            -webkit-tap-highlight-color: transparent;
                        }

                        button:focus, [role="button"]:focus {
                            outline: none;
                        }

                        body {
                            background-color: var(--bg-primary);
                            color: var(--text-primary);
                            min-height: 100vh;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            padding: 2rem 2rem 0 2rem;
                            position: relative;
                            overflow-x: hidden;
                            overflow-y: scroll;
                            transition: background-color 0.3s, color 0.3s;
                        }

                        body::before {
                            content: '';
                            position: fixed;
                            top: 0;
                            left: 0;
                            right: 0;
                            bottom: 0;
                            background: radial-gradient(circle at 50% 50%, var(--radial-glow) 0%, transparent 50%);
                            pointer-events: none;
                        }

                        .container {
                            max-width: 1400px;
                            width: 100%;
                            position: relative;
                            z-index: 1;
                            min-height: calc(100vh - 4rem);
                            display: flex;
                            flex-direction: column;
                            flex: 1;
                        }

                        /* Header */
                        .header {
                            text-align: center;
                            margin-bottom: 2.2rem;
                            border-bottom: 2px solid var(--border-accent);
                            padding-bottom: 1.2rem;
                        }

                        .header h1 {
                            font-size: 2.55rem;
                            font-weight: 900;
                            text-transform: uppercase;
                            letter-spacing: 4px;
                            background: linear-gradient(45deg, var(--accent-bright), var(--accent));
                            -webkit-background-clip: text;
                            -webkit-text-fill-color: transparent;
                            background-clip: text;
                        }

                        .header p {
                            color: var(--text-dim);
                            margin-top: 0.5rem;
                            font-size: 0.85rem;
                            font-weight: 500;
                            letter-spacing: 1px;
                        }

                        /* Search Bar */
                        .search-container {
                            position: relative;
                            margin-bottom: 0.75rem;
                            display: flex;
                            align-items: center;
                            gap: 0.55rem;
                        }

                        .search-bar {
                            flex: 1;
                            min-width: 0;
                            padding: 0.75rem 1.4rem;
                            background: var(--input-bg);
                            border: 2px solid var(--border-accent);
                            border-radius: 50px;
                            color: var(--text-primary);
                            font-size: 0.95rem;
                            font-weight: 500;
                            outline: none;
                            transition: all 0.3s;
                            box-shadow: 0 0 18px var(--accent-glow);
                        }

                        .filter-btn {
                            position: relative;
                            flex-shrink: 0;
                            width: 44px;
                            height: 44px;
                            border-radius: 50%;
                            background: var(--input-bg);
                            border: 2px solid var(--border-accent);
                            box-shadow: 0 0 18px var(--accent-glow);
                            color: var(--text-dim);
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            transition: all 0.2s ease;
                        }
                        .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
                        .filter-btn.active { border-color: var(--accent); color: var(--accent); box-shadow: 0 0 22px var(--accent-glow); }
                        .filter-btn svg { width: 18px; height: 18px; }
                        .filter-btn .filter-badge {
                            position: absolute;
                            top: -3px;
                            right: -3px;
                            width: 10px;
                            height: 10px;
                            border-radius: 50%;
                            background: var(--accent);
                            border: 2px solid #0a0a0a;
                            display: none;
                        }
                        .filter-btn.genre-active .filter-badge { display: block; }

                        .search-bar:focus {
                            border-color: var(--accent-bright);
                            box-shadow: 0 0 28px var(--accent-glow);
                        }

                        .search-bar::placeholder {
                            color: var(--text-muted);
                            font-weight: 400;
                        }

                        /* Dropdown */
                        .dropdown {
                            position: absolute;
                            top: 100%;
                            left: 0;
                            right: 0;
                            background: var(--dropdown-bg);
                            border: 1px solid var(--border-accent);
                            border-top: none;
                            border-radius: 0 0 15px 15px;
                            max-height: 400px;
                            overflow-y: auto;
                            display: none;
                            z-index: 1000;
                            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
                        }

                        .dropdown.active {
                            display: block;
                        }

                        .dropdown-item {
                            padding: 0.85rem 1.5rem;
                            cursor: pointer;
                            transition: all 0.2s;
                            border-bottom: 1px solid var(--border-color);
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                        }

                        .dropdown-item:hover {
                            background: var(--accent);
                            border-bottom-color: var(--accent-bright);
                        }

                        .dropdown-item .channel-name {
                            font-weight: 700;
                            color: var(--text-primary);
                        }

                        .dropdown-item .match-reason {
                            font-size: 0.7rem;
                            color: var(--accent-soft);
                            margin-left: 0.5rem;
                            font-style: italic;
                        }

                        .dropdown-item .loading {
                            display: inline-block;
                            width: 16px;
                            height: 16px;
                            border: 2px solid rgba(255,255,255,.3);
                            border-radius: 50%;
                            border-top-color: #ff0000;
                            animation: spin 1s ease-in-out infinite;
                            margin-right: 8px;
                        }

                        .dropdown-item.error {
                            color: #ff6666;
                            justify-content: center;
                        }

                        /* Main Content */
                        .main-content {
                            display: none;
                            grid-template-columns: 1fr;
                            gap: 1.7rem;
                        }

                        .main-content.visible {
                            display: grid;
                        }

                        /* Recently Added Title */
                        .recently-added-title {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                            margin-bottom: 1rem;
                            grid-column: 1 / -1;
                        }

                        /* Home Grid - Force 3 columns on all devices */
                        .home-grid {
                            display: grid;
                            grid-template-columns: repeat(3, 1fr);
                            gap: 1.5rem;
                            margin-top: 0.5rem;
                        }

                        .home-grid.visible {
                            display: grid;
                        }

                        .home-grid.hidden {
                            display: none;
                        }

                        /* History Grid - Smaller cards on desktop */
                        .history-grid {
                            display: grid;
                            grid-template-columns: repeat(3, 1fr);
                            gap: 1.5rem;
                            margin-top: 2rem;
                        }

                        @media (min-width: 1024px) {
                            .history-grid {
                                grid-template-columns: repeat(6, 1fr);
                            }
                        }

                        .history-grid.visible {
                            display: grid;
                        }

                        .history-grid.hidden {
                            display: none;
                        }

                        .history-header {
                            grid-column: 1 / -1;
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: 0.5rem;
                            padding-bottom: 0.5rem;
                            border-bottom: 1px solid var(--border-accent);
                        }

                        .history-title {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }

                        .clear-history-btn {
                            background: transparent;
                            color: var(--accent-soft);
                            border: 1px solid var(--border-accent);
                            padding: 0.35rem 1rem;
                            border-radius: 6px;
                            font-size: 0.78rem;
                            font-weight: 600;
                            cursor: pointer;
                            transition: all 0.3s;
                        }

                        .clear-history-btn:hover {
                            background: var(--accent);
                            color: white;
                        }

                        /* Modern Anime Card */
                        .anime-card {
                            background: var(--bg-card);
                            border-radius: 10px;
                            overflow: hidden;
                            cursor: pointer;
                            transition: all 0.3s ease, opacity 0.5s ease, transform 0.5s ease;
                            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
                            border: 1px solid var(--border-color);
                            position: relative;
                            width: 100%;
                            padding-bottom: 150%;
                            height: 0;
                        }

                        @supports (aspect-ratio: 2/3) {
                            .anime-card {
                                aspect-ratio: 2/3;
                                padding-bottom: 0;
                                height: auto;
                            }
                        }

                        .home-grid .anime-card {
                            opacity: 0;
                            transform: translateY(20px);
                        }

                        .home-grid .anime-card.fade-in,
                        .no-observer .home-grid .anime-card {
                            opacity: 1;
                            transform: translateY(0);
                        }

                        .anime-card:hover {
                            transform: translateY(-15px);
                            border-color: var(--border-accent);
                            box-shadow: 0 10px 25px var(--accent-glow);
                        }

                        .home-grid .anime-card.fade-in:hover {
                            transform: translateY(-8px) scale(1.02);
                        }

                        /* History Card - Smaller version */
                        .history-card {
                            background: var(--bg-card);
                            border-radius: 10px;
                            overflow: hidden;
                            cursor: pointer;
                            transition: all 0.3s ease;
                            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
                            border: 1px solid var(--border-color);
                            position: relative;
                            width: 100%;
                            padding-bottom: 150%;
                            height: 0;
                            transform: scale(0.8);
                            transform-origin: center;
                        }

                        @supports (aspect-ratio: 2/3) {
                            .history-card {
                                aspect-ratio: 2/3;
                                padding-bottom: 0;
                                height: auto;
                            }
                        }

                        .history-card:hover {
                            transform: translateY(-15px);
                            border-color: var(--border-accent);
                            box-shadow: 0 10px 25px var(--accent-glow);
                            z-index: 5;
                        }

                        .anime-image {
                            position: absolute;
                            top: 0;
                            left: 0;
                            width: 100%;
                            height: 100%;
                            object-fit: cover;
                            display: block;
                        }

                        .anime-info {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            right: 0;
                            padding: 1.5rem 0.8rem 0.8rem;
                            background: linear-gradient(to top, rgba(0,0,0,0.92), transparent);
                            color: white;
                        }

                        .anime-name {
                            font-size: 1rem;
                            font-weight: 700;
                            margin-bottom: 0.25rem;
                            text-shadow: 0 2px 6px rgba(0,0,0,0.8);
                            display: -webkit-box;
                            -webkit-line-clamp: 2;
                            -webkit-box-orient: vertical;
                            overflow: hidden;
                            line-height: 1.3;
                        }

                        /* Smaller text for history cards */
                        .history-card .anime-name {
                            font-size: 0.85rem;
                        }

                        .anime-genres {
                            display: flex;
                            flex-wrap: wrap;
                        }

                        .anime-genres > * {
                            margin: 0 0.3rem 0.3rem 0;
                        }

                        .genre-tag {
                            background: var(--accent);
                            padding: 0.2rem 0.55rem;
                            border-radius: 5px;
                            font-size: 0.65rem;
                            font-weight: 700;
                            color: white;
                            backdrop-filter: blur(4px);
                        }

                        /* History Card Specific */
                        .history-timestamp {
                            position: absolute;
                            top: 8px;
                            right: 8px;
                            background: rgba(0, 0, 0, 0.75);
                            padding: 0.2rem 0.5rem;
                            border-radius: 5px;
                            font-size: 0.55rem;
                            font-weight: 700;
                            color: var(--accent-soft);
                            border: 1px solid var(--border-accent);
                            backdrop-filter: blur(4px);
                            z-index: 2;
                        }

                        .history-episode {
                            position: absolute;
                            bottom: 8px;
                            right: 8px;
                            background: var(--accent);
                            padding: 0.2rem 0.5rem;
                            border-radius: 5px;
                            font-size: 0.55rem;
                            font-weight: 700;
                            color: white;
                            z-index: 2;
                        }

                        /* Anime Detail View */
                        .anime-detail {
                            background: var(--bg-card);
                            border: 2px solid var(--border-accent);
                            border-radius: 12px;
                            padding: 1.5rem;
                            margin-bottom: 2rem;
                            display: none;
                        }

                        .anime-detail.visible {
                            display: block;
                        }

                        .detail-header {
                            display: flex;
                            gap: 2rem;
                        }

                        .detail-image {
                            width: 200px;
                            height: 300px;
                            object-fit: cover;
                            border-radius: 10px;
                            border: 2px solid var(--border-accent);
                            flex-shrink: 0;
                        }

                        .detail-info {
                            flex: 1;
                        }

                        .detail-title {
                            font-size: 1.8rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            margin-bottom: 0.75rem;
                            line-height: 1.25;
                        }

                        .detail-meta {
                            display: flex;
                            flex-direction: column;
                            gap: 0.45rem;
                            margin-top: 0.75rem;
                        }

                        .detail-meta-item {
                            font-size: 0.82rem;
                            font-weight: 500;
                            color: var(--text-muted);
                        }

                        .detail-meta-item span {
                            color: var(--accent-soft);
                            font-weight: 700;
                        }

                        /* Video Player */
                        .video-player-container {
                            background: var(--bg-player);
                            border: 2px solid var(--border-accent);
                            border-radius: 12px;
                            padding: 0;
                            box-shadow: 0 0 30px var(--accent-glow);
                            position: relative;
                            overflow: hidden;
                            max-width: 900px;
                            margin: 0 auto;
                            width: 100%;
                        }

                        #videoPlayer {
                            width: 100%;
                            display: block;
                            background: black;
                            aspect-ratio: 16/9;
                            accent-color: #FA4343;
                        }

                        /* Custom Video Controls */
                        .custom-controls {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            right: 0;
                            background: linear-gradient(transparent, rgba(0,0,0,0.88) 100%);
                            padding: 2rem 0.85rem 0.65rem;
                            opacity: 0;
                            transition: opacity 0.28s ease;
                            z-index: 10;
                            user-select: none;
                        }

                        .video-player-container:hover .custom-controls,
                        .video-player-container.paused .custom-controls,
                        .video-player-container.touch-active .custom-controls {
                            opacity: 1;
                        }

                        /* In fullscreen: hide border, reset radius, only show controls on touch */
                        .video-player-container:fullscreen,
                        .video-player-container:-webkit-full-screen {
                            border: none !important;
                            border-radius: 0 !important;
                            max-width: 100vw !important;
                            width: 100vw !important;
                            height: 100vh !important;
                            box-shadow: none !important;
                            background: #000 !important;
                            display: flex !important;
                            align-items: center !important;
                            justify-content: center !important;
                        }
                        .video-player-container:fullscreen #videoPlayer,
                        .video-player-container:-webkit-full-screen #videoPlayer {
                            width: 100% !important;
                            height: 100% !important;
                            aspect-ratio: unset !important;
                            object-fit: contain !important;
                        }
                        .video-player-container:fullscreen .custom-controls,
                        .video-player-container:-webkit-full-screen .custom-controls {
                            opacity: 0 !important;
                        }
                        .video-player-container:fullscreen.touch-active .custom-controls,
                        .video-player-container:-webkit-full-screen.touch-active .custom-controls {
                            opacity: 1 !important;
                        }

                        @keyframes seekFlash {
                            0%   { opacity: 1; transform: translateY(-50%) scale(1); }
                            100% { opacity: 0; transform: translateY(-50%) scale(1.15); }
                        }

                        .seek-flash {
                            position: absolute;
                            top: 50%;
                            transform: translateY(-50%);
                            background: rgba(0, 0, 0, 0.6);
                            color: #fff;
                            padding: 0.55rem 1.1rem;
                            border-radius: 20px;
                            font-size: 0.9rem;
                            font-weight: 800;
                            pointer-events: none;
                            z-index: 20;
                            animation: seekFlash 0.75s ease-out forwards;
                        }

                        .ctrl-progress-wrapper {
                            width: 100%;
                            padding: 0.9rem 0;
                            cursor: pointer;
                            outline: none;
                            user-select: none;
                            -webkit-user-select: none;
                        }

                        .ctrl-progress-track {
                            height: 4px;
                            background: rgba(255,255,255,0.22);
                            border-radius: 2px;
                            position: relative;
                            transition: height 0.15s ease;
                        }

                        .ctrl-progress-wrapper:hover .ctrl-progress-track {
                            height: 6px;
                        }

                        .ctrl-progress-fill {
                            height: 100%;
                            background: #FA4343;
                            border-radius: 2px;
                            width: 0%;
                            pointer-events: none;
                        }

                        .ctrl-progress-thumb {
                            position: absolute;
                            top: 50%;
                            left: 0%;
                            transform: translate(-50%, -50%) scale(0);
                            width: 13px;
                            height: 13px;
                            background: #FA4343;
                            border-radius: 50%;
                            pointer-events: none;
                            transition: transform 0.15s ease;
                            box-shadow: 0 0 5px rgba(250,67,67,0.7);
                        }

                        .ctrl-progress-wrapper:hover .ctrl-progress-thumb,
                        .ctrl-progress-wrapper.dragging .ctrl-progress-thumb {
                            transform: translate(-50%, -50%) scale(1);
                        }

                        .ctrl-progress-wrapper.dragging .ctrl-progress-track {
                            height: 6px;
                        }

                        .ctrl-progress-wrapper.dragging {
                            cursor: grabbing;
                        }

                        /* Speed popup */
                        .ctrl-speed-wrap {
                            position: relative;
                        }

                        .speed-popup {
                            display: none;
                            position: absolute;
                            bottom: calc(100% + 8px);
                            right: 50%;
                            transform: translateX(50%);
                            background: rgba(18, 18, 18, 0.96);
                            border: 1px solid rgba(255,255,255,0.12);
                            border-radius: 8px;
                            padding: 0.3rem;
                            z-index: 200;
                            min-width: 76px;
                            backdrop-filter: blur(10px);
                        }

                        .speed-popup.open { display: block; }

                        .speed-option {
                            padding: 0.35rem 0.75rem;
                            color: rgba(255,255,255,0.72);
                            font-size: 0.78rem;
                            font-weight: 600;
                            cursor: pointer;
                            border-radius: 5px;
                            text-align: center;
                            white-space: nowrap;
                        }

                        .speed-option:hover { background: rgba(255,255,255,0.1); color: #fff; }
                        .speed-option.active { color: #FA4343; font-weight: 800; }

                        /* Genre filter bar */
                        .genre-filter-bar {
                            display: none;
                            flex-wrap: wrap;
                            gap: 0.45rem;
                            padding: 0.8rem 1rem;
                            margin-bottom: 1rem;
                            background: var(--input-bg);
                            border: 1.5px solid var(--border-accent);
                            border-radius: 16px;
                            box-shadow: 0 4px 24px rgba(0,0,0,0.4);
                            animation: genrePanelIn 0.18s ease;
                        }
                        .genre-filter-bar.expanded { display: flex; }

                        @keyframes genrePanelIn {
                            from { opacity: 0; transform: translateY(-8px); }
                            to   { opacity: 1; transform: translateY(0); }
                        }

                        .genre-filter-chip {
                            padding: 0.28rem 0.85rem;
                            border-radius: 20px;
                            font-size: 0.7rem;
                            font-weight: 700;
                            cursor: pointer;
                            border: 1.5px solid var(--border-accent);
                            color: var(--text-dim);
                            background: transparent;
                            transition: all 0.15s ease;
                            letter-spacing: 0.3px;
                            outline: none;
                            -webkit-tap-highlight-color: transparent;
                            user-select: none;
                            -webkit-user-select: none;
                        }

                        .genre-filter-chip:hover { border-color: var(--accent); color: var(--accent); }
                        .genre-filter-chip.active { background: var(--accent); border-color: var(--accent); color: #fff; }

                        .anime-card.genre-hidden { display: none !important; }

                        .ctrl-row {
                            display: flex;
                            align-items: center;
                            justify-content: space-between;
                            gap: 0.4rem;
                            margin-top: 0.3rem;
                        }

                        .ctrl-left, .ctrl-right {
                            display: flex;
                            align-items: center;
                            gap: 0.2rem;
                        }

                        .ctrl-btn {
                            background: none;
                            border: none;
                            color: white;
                            font-size: 0.95rem;
                            cursor: pointer;
                            padding: 0.25rem 0.35rem;
                            border-radius: 4px;
                            transition: background 0.15s;
                            line-height: 1;
                            min-width: 28px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                        }

                        .ctrl-btn:hover {
                            background: rgba(255,255,255,0.15);
                        }

                        .ctrl-time {
                            color: rgba(255,255,255,0.82);
                            font-size: 0.7rem;
                            font-weight: 600;
                            letter-spacing: 0.3px;
                            white-space: nowrap;
                            padding: 0 0.2rem;
                        }

                        #ctrlVolumeSlider {
                            width: 62px;
                            height: 4px;
                            accent-color: #FA4343;
                            cursor: pointer;
                            vertical-align: middle;
                        }

                        /* Franchise Section */
                        .franchise-section {
                            background: var(--bg-player);
                            border: 1px solid var(--border-accent);
                            border-radius: 12px;
                            padding: 0.9rem 1rem;
                            display: none;
                        }

                        .franchise-section.visible {
                            display: block;
                        }

                        .franchise-label {
                            font-size: 0.68rem;
                            font-weight: 800;
                            letter-spacing: 0.6px;
                            text-transform: uppercase;
                            color: var(--accent);
                            margin-bottom: 0.6rem;
                        }

                        .franchise-list {
                            display: flex;
                            flex-direction: column;
                            gap: 0.4rem;
                            max-height: 152px;
                            overflow-y: auto;
                            scrollbar-width: thin;
                            scrollbar-color: var(--accent) transparent;
                        }

                        .franchise-list::-webkit-scrollbar { width: 4px; }
                        .franchise-list::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }
                        .franchise-list::-webkit-scrollbar-track { background: transparent; }

                        .franchise-card {
                            display: flex;
                            align-items: center;
                            gap: 0.7rem;
                            cursor: pointer;
                            border-radius: 8px;
                            border: 2px solid transparent;
                            background: var(--bg-secondary);
                            padding: 0.35rem 0.5rem 0.35rem 0.35rem;
                            transition: border-color 0.2s, background 0.2s;
                        }

                        .franchise-card:hover {
                            border-color: var(--accent);
                            background: var(--bg-hover, var(--bg-secondary));
                        }

                        .franchise-card.active-franchise {
                            border-color: var(--accent);
                            opacity: 0.55;
                            pointer-events: none;
                        }

                        .franchise-card img {
                            width: 36px;
                            height: 54px;
                            object-fit: cover;
                            border-radius: 5px;
                            flex-shrink: 0;
                            display: block;
                        }

                        .franchise-card-name {
                            font-size: 0.75rem;
                            font-weight: 600;
                            color: var(--text-primary);
                            overflow: hidden;
                            display: -webkit-box;
                            -webkit-line-clamp: 2;
                            -webkit-box-orient: vertical;
                            line-height: 1.35;
                        }

                        /* Episode Buttons */
                        .episodes-section {
                            background: var(--bg-player);
                            border: 1px solid var(--border-accent);
                            border-radius: 12px;
                            padding: 1.5rem;
                            overflow: hidden;
                        }

                        .episodes-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: 1.5rem;
                        }

                        .episodes-title {
                            font-size: 1.1rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                        }

                        .episode-count {
                            background: var(--accent);
                            padding: 0.2rem 1rem;
                            border-radius: 6px;
                            font-size: 0.78rem;
                            font-weight: 700;
                        }

                        .episode-ranges {
                            display: flex;
                            gap: 0.5rem;
                            margin-bottom: 1rem;
                            flex-wrap: wrap;
                        }

                        .episode-range-btn {
                            background: var(--bg-secondary);
                            border: 1px solid var(--border-color);
                            color: var(--text-secondary);
                            padding: 0.4rem 0.9rem;
                            border-radius: 6px;
                            cursor: pointer;
                            font-size: 0.78rem;
                            font-weight: 600;
                            transition: all 0.2s;
                        }

                        .episode-range-btn:hover {
                            border-color: var(--border-accent);
                            color: var(--accent-soft);
                        }

                        .episode-range-btn.active {
                            background: var(--accent);
                            border-color: var(--accent-bright);
                            color: white;
                        }

                        .episodes-grid {
                            display: grid;
                            grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
                            gap: 0.5rem;
                            margin-bottom: 2rem;
                        }

                        .episodes-grid.has-thumbnails {
                            display: flex;
                            flex-direction: column;
                            gap: 0.5rem;
                            max-height: 500px;
                            overflow-y: auto;
                            padding-right: 0.3rem;
                        }

                        .episode-btn {
                            background: var(--bg-secondary);
                            border: 1px solid var(--border-color);
                            color: var(--text-primary);
                            padding: 0.5rem;
                            border-radius: 6px;
                            cursor: pointer;
                            font-weight: 600;
                            transition: all 0.2s;
                            font-size: 0.85rem;
                        }

                        .episode-btn.has-thumb {
                            display: flex;
                            flex-direction: row;
                            align-items: stretch;
                            padding: 0;
                            overflow: hidden;
                            min-height: 80px;
                            text-align: left;
                        }

                        .episode-btn .ep-thumb {
                            width: 140px;
                            min-width: 140px;
                            height: 80px;
                            object-fit: cover;
                            display: block;
                        }

                        .episode-btn .ep-thumb-blank {
                            background: #222;
                        }

                        .episode-btn .ep-info {
                            flex: 1;
                            min-width: 0;
                            padding: 0.5rem 0.7rem;
                            display: flex;
                            flex-direction: column;
                            gap: 0.2rem;
                            overflow: hidden;
                        }

                        .episode-btn .ep-number {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                        }

                        .episode-btn .ep-title {
                            font-size: 0.8rem;
                            color: var(--text-primary);
                            font-weight: 600;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                        }

                        .episode-btn .ep-desc {
                            font-size: 0.7rem;
                            color: var(--text-muted);
                            line-height: 1.3;
                            overflow: hidden;
                            display: -webkit-box;
                            -webkit-line-clamp: 2;
                            -webkit-box-orient: vertical;
                        }

                        .episode-btn:hover {
                            background: var(--accent);
                            border-color: var(--accent-bright);
                            color: white;
                        }

                        .episode-btn.has-thumb:hover {
                            border-color: var(--accent-bright);
                            background: var(--bg-card);
                        }

                        .episode-btn.active {
                            background: var(--accent);
                            border-color: var(--accent-bright);
                        }

                        .episode-btn.has-thumb.active {
                            border-color: var(--accent-bright);
                            border-width: 2px;
                            background: var(--bg-primary);
                        }

                        /* Synopsis Section — integrated, no separate box */
                        .synopsis-section {
                            padding: 1rem 0 0 0;
                            margin-top: 0.75rem;
                        }

                        .synopsis-title {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            text-transform: uppercase;
                            letter-spacing: 0.5px;
                            margin-bottom: 0.5rem;
                        }

                        .synopsis-content {
                            color: var(--text-secondary);
                            line-height: 1.65;
                            font-size: 0.9rem;
                            font-weight: 400;
                        }

                        .synopsis-genres {
                            display: flex;
                            flex-wrap: wrap;
                            gap: 0.4rem;
                            margin-top: 0.75rem;
                        }

                        .synopsis-genre-tag {
                            background: transparent;
                            border: 1px solid var(--border-accent);
                            color: var(--accent-soft);
                            padding: 0.2rem 0.65rem;
                            border-radius: 20px;
                            font-size: 0.72rem;
                            font-weight: 600;
                        }

                        .genres-list {
                            display: flex;
                            flex-wrap: wrap;
                            gap: 0.5rem;
                            margin-top: 1rem;
                        }

                        /* Footer Navigation - Fixed at bottom */
                        .footer-nav {
                            position: sticky;
                            bottom: 0;
                            margin-top: 1.5rem;
                            padding: 0.5rem 0;
                            border-top: 1px solid var(--border-accent);
                            background-color: var(--footer-bg);
                            display: flex;
                            justify-content: center;
                            gap: 3rem;
                            width: 100%;
                            z-index: 100;
                            transition: background-color 0.3s;
                        }

                        .nav-btn {
                            background: transparent;
                            border: none;
                            color: var(--text-dim);
                            font-size: 1rem;
                            font-weight: 600;
                            cursor: pointer;
                            transition: all 0.3s;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 0.1rem;
                            padding: 0.2rem 1rem;
                        }

                        .nav-btn:hover {
                            color: var(--accent-soft);
                        }

                        .nav-btn.active {
                            color: var(--accent-bright);
                        }

                        .nav-btn.active span {
                            border-bottom: 2px solid var(--accent-bright);
                            padding-bottom: 1px;
                        }

                        .nav-btn.hidden {
                            display: none;
                        }

                        .nav-btn i {
                            font-size: 1.1rem;
                        }

                        .nav-btn span {
                            font-size: 0.62rem;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.7px;
                        }

                        /* No Results */
                        .no-results {
                            grid-column: 1 / -1;
                            padding: 3rem;
                            text-align: center;
                            color: var(--text-dim);
                            font-style: italic;
                            background: var(--bg-card);
                            border-radius: 10px;
                            border: 1px solid var(--border-color);
                        }

                        /* Profile View */
                        .profile-view {
                            grid-column: 1 / -1;
                            background: var(--bg-card);
                            border-radius: 12px;
                            padding: 3rem;
                            text-align: center;
                            border: 1px solid var(--border-color);
                        }

                        .profile-avatar {
                            font-size: 4rem;
                            margin-bottom: 1rem;
                        }

                        .profile-title {
                            font-size: 1.5rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            margin-bottom: 0.5rem;
                        }

                        .profile-stats {
                            margin-top: 2rem;
                            color: var(--text-muted);
                            font-size: 1rem;
                        }

                        .profile-stats span {
                            color: var(--accent-soft);
                            font-weight: 700;
                        }

                        /* Profile Footer */
                        .profile-footer {
                            margin-top: 2.5rem;
                            padding-top: 1.5rem;
                            border-top: 1px solid var(--border-color);
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 1rem;
                        }

                        .profile-footer-icons {
                            display: flex;
                            gap: 0.75rem;
                            align-items: center;
                        }

                        .profile-footer-icon-btn {
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            width: 40px;
                            height: 40px;
                            border-radius: 50%;
                            border: 1.5px solid var(--border-accent);
                            background: var(--bg-secondary);
                            color: var(--text-muted);
                            cursor: pointer;
                            transition: all 0.22s ease;
                        }

                        .profile-footer-icon-btn:hover {
                            border-color: var(--accent);
                            color: var(--accent-soft);
                            background: var(--bg-card);
                            box-shadow: 0 0 10px var(--accent-glow);
                            transform: translateY(-2px);
                        }

                        .profile-footer-icon-btn svg {
                            width: 18px;
                            height: 18px;
                            fill: currentColor;
                        }

                        .footer-text {
                            font-size: 0.7rem;
                            color: var(--text-muted);
                            opacity: 0.6;
                            letter-spacing: 0.4px;
                        }

                        /* Socials Popup */
                        .socials-popup-backdrop {
                            position: fixed;
                            inset: 0;
                            background: rgba(0,0,0,0.55);
                            z-index: 9000;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            animation: fadeIn 0.18s ease;
                        }

                        .socials-popup-card {
                            background: var(--bg-card);
                            border: 1px solid var(--border-accent);
                            border-radius: 16px;
                            padding: 2rem 2.5rem;
                            text-align: center;
                            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px var(--accent-glow);
                            min-width: 280px;
                            animation: slideUp 0.22s ease;
                        }

                        @keyframes slideUp {
                            from { opacity: 0; transform: translateY(18px); }
                            to   { opacity: 1; transform: translateY(0); }
                        }

                        .socials-popup-title {
                            font-size: 0.75rem;
                            font-weight: 800;
                            letter-spacing: 1.5px;
                            text-transform: uppercase;
                            color: var(--text-muted);
                            margin-bottom: 1.5rem;
                        }

                        .socials-popup-links {
                            display: flex;
                            justify-content: center;
                            gap: 1.25rem;
                        }

                        .social-link {
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 0.4rem;
                            text-decoration: none;
                            color: var(--text-muted);
                            transition: all 0.22s ease;
                        }

                        .social-link:hover {
                            color: var(--accent-soft);
                            transform: translateY(-3px);
                        }

                        .social-link-icon {
                            width: 46px;
                            height: 46px;
                            border-radius: 12px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border: 1.5px solid var(--border-color);
                            background: var(--bg-secondary);
                            transition: all 0.22s ease;
                        }

                        .social-link:hover .social-link-icon {
                            border-color: var(--accent);
                            box-shadow: 0 4px 14px var(--accent-glow);
                        }

                        .social-link-icon svg {
                            width: 22px;
                            height: 22px;
                            fill: currentColor;
                        }

                        .social-link span {
                            font-size: 0.65rem;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        .socials-popup-close {
                            margin-top: 1.5rem;
                            font-size: 0.7rem;
                            color: var(--text-muted);
                            opacity: 0.5;
                            cursor: pointer;
                        }

                        .socials-popup-close:hover { opacity: 1; }

                        /* ToS Popup */
                        .tos-popup-card {
                            background: var(--bg-card);
                            border: 1px solid var(--border-accent);
                            border-radius: 16px;
                            padding: 2rem 2rem;
                            text-align: left;
                            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
                            max-width: 360px;
                            width: 90vw;
                            animation: slideUp 0.22s ease;
                        }

                        .tos-popup-title {
                            font-size: 1rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            margin-bottom: 1rem;
                        }

                        .tos-popup-body {
                            font-size: 0.75rem;
                            color: var(--text-dim);
                            line-height: 1.7;
                        }

                        .tos-popup-body p { margin-bottom: 0.65rem; }

                        /* Theme Toggle Pill */
                        .theme-toggle {
                            display: inline-flex;
                            background: var(--bg-secondary);
                            border: 1.5px solid var(--border-accent);
                            border-radius: 50px;
                            padding: 3px;
                            margin-top: 1.5rem;
                            box-shadow: 0 2px 10px var(--accent-glow);
                        }

                        .theme-toggle-option {
                            padding: 0.45rem 1.3rem;
                            border-radius: 50px;
                            font-size: 0.82rem;
                            font-weight: 700;
                            color: var(--text-muted);
                            cursor: pointer;
                            transition: all 0.25s;
                            user-select: none;
                            letter-spacing: 0.3px;
                        }

                        .theme-toggle-option.active {
                            background: var(--accent);
                            color: white;
                            box-shadow: 0 2px 8px var(--accent-glow);
                        }

                        /* Bookmark Button */
                        .bookmark-btn {
                            background: var(--bg-player);
                            border: 1px solid var(--border-accent);
                            color: var(--accent-soft);
                            padding: 0.45rem 0.6rem;
                            border-radius: 6px;
                            cursor: pointer;
                            font-size: 1rem;
                            transition: all 0.25s;
                            line-height: 1;
                        }

                        .bookmark-btn:hover {
                            background: var(--accent);
                            color: white;
                        }

                        .bookmark-btn.bookmarked {
                            background: var(--accent);
                            color: white;
                            border-color: var(--accent-bright);
                        }

                        /* Video Player Hover Overlay */
                        .video-hover-overlay {
                            position: absolute;
                            top: 0;
                            left: 0;
                            right: 0;
                            padding: 0.75rem 1rem 1.2rem;
                            background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, transparent 100%);
                            display: flex;
                            align-items: flex-start;
                            gap: 0.6rem;
                            opacity: 0;
                            transition: opacity 0.25s ease;
                            pointer-events: none;
                            z-index: 5;
                        }

                        .video-player-container:hover .video-hover-overlay,
                        .video-player-container.paused .video-hover-overlay,
                        .video-player-container.touch-active .video-hover-overlay {
                            opacity: 1;
                        }

                        .video-player-container:fullscreen .video-hover-overlay,
                        .video-player-container:-webkit-full-screen .video-hover-overlay {
                            opacity: 0 !important;
                        }
                        .video-player-container:fullscreen.touch-active .video-hover-overlay,
                        .video-player-container:-webkit-full-screen.touch-active .video-hover-overlay {
                            opacity: 1 !important;
                        }

                        .video-hover-dot {
                            width: 7px;
                            height: 7px;
                            background: var(--accent-bright);
                            border-radius: 50%;
                            flex-shrink: 0;
                            margin-top: 4px;
                        }

                        .video-hover-lines {
                            display: flex;
                            flex-direction: column;
                            gap: 0.15rem;
                            min-width: 0;
                        }

                        .video-hover-main {
                            color: white;
                            font-size: 0.82rem;
                            font-weight: 800;
                            letter-spacing: 0.2px;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            text-shadow: 0 1px 4px rgba(0,0,0,0.9);
                        }

                        .video-hover-sub {
                            color: rgba(255,255,255,0.7);
                            font-size: 0.72rem;
                            font-weight: 500;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            text-shadow: 0 1px 3px rgba(0,0,0,0.8);
                            display: none;
                        }

                        .video-hover-sub.visible {
                            display: block;
                        }

                        /* Scrollbar */
                        * {
                            scrollbar-width: thin;
                            scrollbar-color: var(--border-accent) var(--scrollbar-track);
                        }

                        ::-webkit-scrollbar {
                            width: 6px;
                            height: 6px;
                        }

                        ::-webkit-scrollbar-track {
                            background: var(--scrollbar-track);
                        }

                        ::-webkit-scrollbar-thumb {
                            background: var(--border-accent);
                            border-radius: 4px;
                        }

                        ::-webkit-scrollbar-thumb:hover {
                            background: var(--accent-bright);
                        }

                        @supports not selector(::-webkit-scrollbar) {
                            html {
                                scrollbar-width: thin;
                                scrollbar-color: var(--border-accent) var(--scrollbar-track);
                            }
                        }

                        /* Loading */
                        .loading {
                            display: inline-block;
                            width: 20px;
                            height: 20px;
                            border: 2px solid rgba(255,255,255,.3);
                            border-radius: 50%;
                            border-top-color: var(--accent-bright);
                            animation: spin 1s ease-in-out infinite;
                        }

                        .load-more-container {
                            grid-column: 1 / -1;
                            display: flex;
                            justify-content: center;
                            margin-top: 2rem;
                            margin-bottom: 2rem;
                        }

                        .load-more-btn {
                            background: var(--bg-card);
                            color: var(--accent-soft);
                            border: 2px solid var(--border-accent);
                            padding: 0.8rem 2.5rem;
                            border-radius: 50px;
                            font-size: 0.9rem;
                            font-weight: 700;
                            letter-spacing: 1px;
                            cursor: pointer;
                            transition: all 0.3s;
                            box-shadow: 0 0 15px var(--accent-glow);
                        }

                        .load-more-btn:hover {
                            background: var(--accent);
                            color: white;
                            box-shadow: 0 0 25px var(--accent-glow);
                            transform: translateY(-2px);
                        }

                        .load-more-btn.hidden {
                            display: none;
                        }

                        /* Seasonal Anime Section */
                        .seasonal-section {
                            margin-bottom: 2rem;
                            position: relative;
                        }

                        .seasonal-section.hidden {
                            display: none;
                        }

                        .seasonal-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            position: absolute;
                            top: 0;
                            left: 0;
                            right: 0;
                            z-index: 5;
                            padding: 0.85rem 1rem;
                            background: linear-gradient(to bottom, rgba(0,0,0,0.72) 0%, transparent 100%);
                            margin-bottom: 0;
                        }

                        .seasonal-title {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }

                        .seasonal-nav {
                            display: flex;
                        }

                        .seasonal-nav > *:not(:last-child) {
                            margin-right: 0.5rem;
                        }

                        .seasonal-nav-btn {
                            background: var(--accent-glow);
                            border: 1px solid var(--border-accent);
                            color: var(--text-primary);
                            width: 32px;
                            height: 32px;
                            border-radius: 50%;
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 1rem;
                            transition: all 0.3s;
                        }

                        .seasonal-nav-btn:hover {
                            background: var(--accent);
                            border-color: var(--accent-bright);
                            color: white;
                        }

                        .seasonal-track-wrapper {
                            overflow: hidden;
                            position: relative;
                        }

                        .seasonal-track {
                            display: flex;
                            transition: transform 0.4s ease;
                        }

                        .seasonal-track > * {
                            margin-right: 1rem;
                        }
                        .seasonal-track > *:last-child {
                            margin-right: 0;
                        }

                        .seasonal-card {
                            flex: 0 0 calc(50% - 0.5rem);
                            position: relative;
                            border-radius: 10px;
                            overflow: hidden;
                            cursor: pointer;
                            border: 1px solid var(--border-color);
                            transition: all 0.3s ease;
                            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
                        }

                        .seasonal-card:hover {
                            border-color: var(--border-accent);
                            box-shadow: 0 10px 25px var(--accent-glow);
                            transform: translateY(-5px);
                        }

                        .seasonal-card-image {
                            width: 100%;
                            height: 260px;
                            object-fit: cover;
                            display: block;
                        }

                        @supports (aspect-ratio: 16/9) {
                            .seasonal-card-image {
                                aspect-ratio: 16/9;
                                height: auto;
                            }
                        }

                        .seasonal-card-overlay {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            right: 0;
                            padding: 2rem 1rem 1rem;
                            background: linear-gradient(to top, rgba(0,0,0,0.95), rgba(0,0,0,0.4), transparent);
                            display: flex;
                            justify-content: space-between;
                            align-items: flex-end;
                        }

                        .seasonal-card-name {
                            font-size: 1rem;
                            font-weight: 700;
                            color: white;
                            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
                            flex: 1;
                            margin-right: 0.5rem;
                        }

                        .seasonal-watch-btn {
                            background: var(--accent);
                            border: none;
                            color: white;
                            padding: 0.4rem 1rem;
                            border-radius: 6px;
                            font-size: 0.78rem;
                            font-weight: 700;
                            cursor: pointer;
                            transition: all 0.3s;
                            white-space: nowrap;
                            flex-shrink: 0;
                        }

                        .seasonal-watch-btn:hover {
                            background: var(--accent-bright);
                        }

                        @media (min-width: 1024px) {
                            .seasonal-card {
                                flex: 0 0 calc(33.333% - 0.667rem);
                            }
                        }

                        @media (max-width: 768px) {
                            .seasonal-section {
                                margin-left: -1rem;
                                margin-right: -1rem;
                                width: calc(100% + 2rem);
                                margin-bottom: 1.25rem;
                                border-radius: 0;
                            }

                            .seasonal-header {
                                padding: 0.85rem 1rem;
                            }

                            .seasonal-track-wrapper {
                                border-radius: 0;
                            }

                            .seasonal-card {
                                flex: 0 0 100%;
                                border-radius: 0;
                                border-left: none;
                                border-right: none;
                            }

                            .seasonal-card-image {
                                height: 280px;
                            }

                            .seasonal-card-name {
                                font-size: 1rem;
                            }

                            .seasonal-card-overlay {
                                padding: 2rem 1rem 1rem;
                            }

                            .seasonal-watch-btn {
                                font-size: 0.75rem;
                                padding: 0.35rem 1rem;
                            }
                        }

                        /* Recently Added Row */
                        .recently-added-section {
                            margin-bottom: 1.25rem;
                        }

                        .recently-added-section.hidden {
                            display: none;
                        }

                        .section-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: 0.85rem;
                        }

                        .section-label {
                            font-size: 0.85rem;
                            font-weight: 800;
                            color: var(--accent-soft);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }

                        .ra-scroll-btn {
                            background: none;
                            border: 1px solid var(--border-color, #333);
                            border-radius: 50%;
                            width: 28px;
                            height: 28px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 1.2rem;
                            line-height: 1;
                            color: var(--text-main, #ccc);
                            cursor: pointer;
                            transition: background 0.2s, border-color 0.2s, color 0.2s;
                            flex-shrink: 0;
                            padding: 0;
                        }
                        .ra-scroll-btn:hover {
                            background: var(--accent, #e63946);
                            border-color: var(--accent, #e63946);
                            color: #fff;
                        }

                        .recently-added-row {
                            display: flex;
                            gap: 0.75rem;
                            overflow-x: auto;
                            scroll-snap-type: x proximity;
                            -webkit-overflow-scrolling: touch;
                            cursor: grab;
                            padding-bottom: 4px;
                            scrollbar-width: none;
                        }

                        .recently-added-row::-webkit-scrollbar {
                            display: none;
                        }

                        .recently-added-row.is-dragging {
                            cursor: grabbing;
                            scroll-behavior: auto;
                        }

                        .recently-added-row .ra-card {
                            flex: 0 0 calc(33.333% - 0.5rem);
                            scroll-snap-align: start;
                            position: relative;
                            border-radius: 10px;
                            overflow: hidden;
                            cursor: pointer;
                            border: 1px solid var(--border-color);
                            transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
                            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
                            background: var(--bg-card);
                            aspect-ratio: 2/3;
                        }

                        .recently-added-row .ra-card:hover {
                            border-color: var(--border-accent);
                            box-shadow: 0 8px 22px var(--accent-glow);
                            transform: translateY(-6px);
                        }

                        .recently-added-row .ra-card img {
                            position: absolute;
                            top: 0; left: 0;
                            width: 100%; height: 100%;
                            object-fit: cover;
                            display: block;
                        }

                        .recently-added-row .ra-card .ra-info {
                            position: absolute;
                            bottom: 0; left: 0; right: 0;
                            padding: 1.5rem 0.6rem 0.6rem;
                            background: linear-gradient(to top, rgba(0,0,0,0.92), transparent);
                        }

                        .recently-added-row .ra-card .ra-name {
                            font-size: 0.72rem;
                            font-weight: 700;
                            color: #fff;
                            text-shadow: 0 1px 4px rgba(0,0,0,0.8);
                            display: -webkit-box;
                            -webkit-line-clamp: 2;
                            -webkit-box-orient: vertical;
                            overflow: hidden;
                            line-height: 1.3;
                        }

                        .recently-added-empty {
                            font-size: 0.8rem;
                            color: var(--text-dim);
                            font-style: italic;
                            padding: 0.5rem 0;
                        }

                        /* Other Series section label */
                        .other-series-header {
                            margin-bottom: 0.85rem;
                        }

                        /* Continue Watching Section */
                        .continue-watching-section {
                            margin-bottom: 1.25rem;
                        }

                        .continue-watching-section.hidden {
                            display: none;
                        }

                        .continue-watching-grid {
                            display: flex;
                            flex-direction: row;
                            gap: 0.75rem;
                            overflow-x: auto;
                            scroll-snap-type: x proximity;
                            -webkit-overflow-scrolling: touch;
                            scrollbar-width: none;
                            padding-bottom: 0.25rem;
                            cursor: grab;
                        }

                        .continue-watching-grid::-webkit-scrollbar {
                            display: none;
                        }

                        .continue-watching-grid.is-dragging {
                            cursor: grabbing;
                            user-select: none;
                        }

                        /* Episode thumbnail card for Continue Watching */
                        .cw-card {
                            position: relative;
                            border-radius: 10px;
                            overflow: hidden;
                            cursor: pointer;
                            border: 1px solid var(--border-color);
                            transition: all 0.28s ease;
                            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
                            background: #0d0d0d;
                            aspect-ratio: 16/9;
                            min-width: 260px;
                            width: 260px;
                            flex-shrink: 0;
                            scroll-snap-align: start;
                        }

                        .cw-card:hover {
                            border-color: var(--border-accent);
                            box-shadow: 0 10px 25px var(--accent-glow);
                            transform: translateY(-4px);
                        }

                        .cw-thumbnail {
                            position: absolute;
                            top: 0;
                            left: 0;
                            width: 100%;
                            height: 100%;
                            object-fit: cover;
                            display: block;
                        }

                        .cw-overlay {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            right: 0;
                            padding: 2rem 0.85rem 0.65rem;
                            background: linear-gradient(to top, rgba(0,0,0,0.54) 55%, transparent);
                        }

                        .cw-anime-name {
                            font-size: 0.9rem;
                            font-weight: 700;
                            color: #fff;
                            text-shadow: 0 1px 4px rgba(0,0,0,0.48);
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            margin-bottom: 0.2rem;
                        }

                        .cw-ep-label {
                            font-size: 0.7rem;
                            font-weight: 600;
                            color: var(--accent-soft);
                        }

                        .cw-progress-bar-container {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            width: 100%;
                            height: 3px;
                            background: rgba(255, 255, 255, 0.15);
                            z-index: 3;
                        }

                        .cw-progress-bar {
                            height: 100%;
                            background: #FA4343;
                            width: 0%;
                            transition: width 0.3s;
                        }

                        .progress-bar-container {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            width: 100%;
                            height: 4px;
                            background: rgba(255, 255, 255, 0.1);
                            z-index: 3;
                        }

                        .progress-bar {
                            height: 100%;
                            background: #ff0000;
                            width: 0%;
                            transition: width 0.3s;
                        }

                        @keyframes spin {
                            to { transform: rotate(360deg); }
                        }

                        /* Desktop Styles */
                        @media (min-width: 1024px) {
                            .continue-watching-section {
                                margin-bottom: 2rem;
                            }
                            .continue-watching-grid {
                                gap: 1rem;
                            }
                            .cw-card {
                                min-width: 320px;
                                width: 320px;
                            }
                            .home-grid {
                                grid-template-columns: repeat(5, 1fr) !important;
                                gap: 1rem;
                            }

                            .recently-added-row .ra-card {
                                flex: 0 0 calc(20% - 0.6rem);
                            }

                            /* History grid maintains more columns on desktop */
                            .history-grid {
                                grid-template-columns: repeat(5, 1fr) !important;
                                gap: 1rem;
                            }

                            .anime-name {
                                font-size: 0.85rem;
                            }

                        }

                        @media (max-width: 1023px) and (min-width: 769px) {
                            .home-grid, .history-grid {
                                grid-template-columns: repeat(3, 1fr) !important;
                            }
                        }

                        /* Responsive - Force 3 columns on all devices */
                        @media (max-width: 768px) {
                            body {
                                padding: 1rem 1rem 0 1rem;
                            }

                            .header h1 {
                                font-size: 1.8rem;
                            }

                            .home-grid, .history-grid {
                                grid-template-columns: repeat(3, 1fr) !important;
                                gap: 0.5rem;
                            }

                            /* Remove scaling on mobile for history cards */
                            .history-card {
                                transform: scale(1);
                                margin: 0;
                            }

                            .history-card:hover {
                                transform: scale(1) translateY(-10px);
                            }

                            .anime-card, .history-card {
                                aspect-ratio: 2/3;
                            }

                            .anime-name {
                                font-size: 0.7rem;
                                -webkit-line-clamp: 2;
                            }

                            .history-card .anime-name {
                                font-size: 0.7rem;
                            }

                            .genre-tag {
                                font-size: 0.5rem;
                                padding: 0.1rem 0.3rem;
                            }

                            .history-timestamp, .history-episode {
                                font-size: 0.5rem;
                                padding: 0.1rem 0.3rem;
                            }

                            .detail-header {
                                flex-direction: column;
                                gap: 1rem;
                            }

                            .detail-image {
                                width: 150px;
                                height: 225px;
                                margin: 0 auto;
                            }

                            .detail-title {
                                font-size: 1.5rem;
                                text-align: center;
                            }

                            .footer-nav {
                                gap: 1rem;
                                margin-left: -1rem;
                                margin-right: -1rem;
                                width: calc(100% + 2rem);
                            }

                            .nav-btn {
                                padding: 0.3rem 0.5rem;
                            }

                            .episodes-section {
                                padding: 0.8rem;
                            }

                            .episodes-grid {
                                grid-template-columns: repeat(auto-fill, minmax(50px, 1fr));
                            }

                            .episodes-grid.has-thumbnails {
                                max-height: 400px;
                            }

                            .episode-btn.has-thumb .ep-thumb {
                                width: 90px;
                                min-width: 90px;
                                height: 55px;
                            }

                            .episode-btn.has-thumb {
                                min-height: 55px;
                            }

                            .episode-btn .ep-info {
                                padding: 0.3rem 0.5rem;
                            }

                            .episode-btn .ep-number {
                                font-size: 0.75rem;
                            }

                            .episode-btn .ep-title {
                                font-size: 0.65rem;
                            }

                            .episode-btn .ep-desc {
                                font-size: 0.55rem;
                                -webkit-line-clamp: 1;
                            }

                            .episode-btn {
                                font-size: 0.7rem;
                                padding: 0.4rem 0.2rem;
                            }

                        }

                        @media (max-width: 480px) {
                            .home-grid, .history-grid {
                                gap: 0.3rem;
                            }

                            .anime-name {
                                font-size: 0.6rem;
                            }

                            .anime-info {
                                padding: 1rem 0.3rem 0.3rem;
                            }
                        }

                        /* Ensure 3 columns on very small devices */
                        @media (max-width: 360px) {
                            .home-grid, .history-grid {
                                grid-template-columns: repeat(3, 1fr) !important;
                                gap: 0.2rem;
                            }

                            .anime-name {
                                font-size: 0.55rem;
                            }
                        }
                    </style>
                </head>
                <body>
                    <div class="container">
                        <div class="header">
                            <h1>Itsukime</h1>
                            <p>@axzyv</p>
                        </div>

                        <div class="search-container">
                            <input 
                                type="text" 
                                class="search-bar" 
                                id="searchInput" 
                                placeholder="🔍 Search your search.."
                                autocomplete="off"
                            >
                            <button class="filter-btn" id="filterBtn" title="Filter by genre">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="4" y1="6" x2="20" y2="6"/>
                                    <line x1="8" y1="12" x2="16" y2="12"/>
                                    <line x1="11" y1="18" x2="13" y2="18"/>
                                </svg>
                                <span class="filter-badge"></span>
                            </button>
                            <div class="dropdown" id="dropdown"></div>
                        </div>

                        <!-- Genre Filter Bar -->
                        <div class="genre-filter-bar" id="genreFilterBar"></div>

                        <!-- Seasonal Anime Section -->
                        <div class="seasonal-section" id="seasonalSection">
                            <div class="seasonal-header">
                                <span class="seasonal-title">Spring 2026 Peaks</span>
                                <div class="seasonal-nav">
                                    <button class="seasonal-nav-btn" id="seasonalPrev">&#8249;</button>
                                    <button class="seasonal-nav-btn" id="seasonalNext">&#8250;</button>
                                </div>
                            </div>
                            <div class="seasonal-track-wrapper">
                                <div class="seasonal-track" id="seasonalTrack"></div>
                            </div>
                        </div>

                        <!-- Continue Watching Section (smaller cards) -->
                        <div id="continueWatchingSection" class="continue-watching-section hidden">
                            <div class="history-header">
                                <h2 class="history-title">Continue Watching</h2>
                            </div>
                            <div class="continue-watching-grid" id="continueWatchingGrid"></div>
                        </div>

                        <!-- Recently Added Horizontal Scroll Section -->
                        <div class="recently-added-section" id="recentlyAddedSection">
                            <div class="section-header">
                                <span class="section-label">Added Today</span>
                                <button class="ra-scroll-btn" id="raScrollBtn" aria-label="Scroll right">&#8250;</button>
                            </div>
                            <div class="recently-added-row" id="recentlyAddedRow"></div>
                        </div>

                        <!-- Other Series Title -->
                        <div class="recently-added-title other-series-header" id="recentlyAddedTitle">More Series</div>

                        <!-- Home Grid -->
                        <style>
                            .hidden-anime {
                                display: none !important;
                            }
                        </style>
                        <div class="home-grid" id="homeGrid">
                            <% if (animeMetadata && Object.keys(animeMetadata).length > 0) { %>
                                <% Object.entries(animeMetadata).forEach(([channelName, metadata], index) => { %>
                                    <div class="anime-card <%= index >= 80 ? 'hidden-anime' : '' %>" data-channel="<%= channelName %>" data-index="<%= index %>" data-genres="<%= (metadata.genres || []).join(',') %>">
                                        <img src="<%= metadata.imageUrl %>" alt="<%= metadata.name %>" class="anime-image" loading="<%= index < 20 ? 'eager' : 'lazy' %>" onerror="this.src='https://via.placeholder.com/300x450?text=No+Image'">
                                        <div class="anime-info">
                                            <div class="anime-name"><%= metadata.name %></div>
                                            <div class="anime-genres">
                                                <% (metadata.genres || []).slice(0, 2).forEach(genre => { %>
                                                    <span class="genre-tag"><%= genre %></span>
                                                <% }); %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>

                        <div class="load-more-container" id="loadMoreContainer">
                            <button class="load-more-btn" id="loadMoreBtn">LOAD MORE</button>
                        </div>

                        <!-- History Grid -->
                        <div class="history-grid hidden" id="historyGrid">
                            <div class="history-header">
                                <h2 class="history-title">History</h2>
                                <button class="clear-history-btn" id="clearHistoryBtn">Clear</button>
                            </div>
                            <div id="historyItems" style="display: contents;"></div>
                        </div>

                        <!-- Main Content (Video Player and Episodes + Synopsis below) -->
                        <div class="main-content" id="mainContent">
                            <div class="video-player-container">
                                <div class="video-hover-overlay">
                                    <div class="video-hover-dot"></div>
                                    <div class="video-hover-lines">
                                        <span class="video-hover-main" id="videoTitleText">Select an episode to start watching</span>
                                        <span class="video-hover-sub" id="videoEpTitle"></span>
                                    </div>
                                </div>
                                <video id="videoPlayer">
                                    <source src="" type="video/mp4">
                                    Your browser does not support the video tag.
                                </video>
                                <div class="custom-controls" id="customControls">
                                    <div class="ctrl-progress-wrapper" id="ctrlProgressWrapper">
                                        <div class="ctrl-progress-track">
                                            <div class="ctrl-progress-fill" id="ctrlProgressFill"></div>
                                            <div class="ctrl-progress-thumb" id="ctrlProgressThumb"></div>
                                        </div>
                                    </div>
                                    <div class="ctrl-row">
                                        <div class="ctrl-left">
                                            <button class="ctrl-btn" id="ctrlPlayBtn">▶</button>
                                            <span class="ctrl-time" id="ctrlTime">0:00 / 0:00</span>
                                        </div>
                                        <div class="ctrl-right">
                                            <button class="ctrl-btn" id="ctrlMuteBtn">🔊</button>
                                            <input type="range" id="ctrlVolumeSlider" min="0" max="1" step="0.05" value="1">
                                            <div class="ctrl-speed-wrap" id="ctrlSpeedWrap">
                                                <button class="ctrl-btn" id="ctrlSpeedBtn" title="Playback speed" style="font-size:0.72rem;font-weight:800;min-width:34px;">1×</button>
                                                <div class="speed-popup" id="speedPopup">
                                                    <div class="speed-option" data-speed="0.25">0.25×</div>
                                                    <div class="speed-option" data-speed="0.5">0.5×</div>
                                                    <div class="speed-option" data-speed="0.75">0.75×</div>
                                                    <div class="speed-option active" data-speed="1">1×</div>
                                                    <div class="speed-option" data-speed="1.25">1.25×</div>
                                                    <div class="speed-option" data-speed="1.5">1.5×</div>
                                                    <div class="speed-option" data-speed="2">2×</div>
                                                    <div class="speed-option" data-speed="4">4×</div>
                                                </div>
                                            </div>
                                            <div class="ctrl-speed-wrap" id="ctrlDownloadWrap">
                                                <button class="ctrl-btn" id="ctrlDownloadBtn" title="Download episode">⬇</button>
                                                <div class="speed-popup" id="downloadPopup" style="min-width:140px; text-align:center;">
                                                    <div style="padding:0.25rem 0.5rem 0.4rem; font-size:0.68rem; color:rgba(255,255,255,0.45); letter-spacing:0.5px; text-transform:uppercase;">Download</div>
                                                    <a id="downloadLink" href="#" style="display:block; padding:0.4rem 0.75rem; color:#FA4343; font-size:0.8rem; font-weight:800; text-decoration:none; border-radius:5px; background:rgba(250,67,67,0.12); margin:0 0.1rem 0.1rem;">⬇ Download Video</a>
                                                </div>
                                            </div>
                                            <button class="ctrl-btn" id="ctrlFsBtn" title="Fullscreen">⛶</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="episodes-section">
                                <div class="episodes-header">
                                    <span class="episodes-title" id="currentChannelName">Select a channel</span>
                                    <span class="episode-count" id="episodeCount">0</span>
                                </div>
                                <div class="episode-ranges" id="episodeRanges"></div>
                                <div class="episodes-grid" id="episodesGrid"></div>
                            </div>

                            <!-- Franchise / Related Seasons -->
                            <div class="franchise-section" id="franchiseSection">
                                <div class="franchise-label">More from this Franchise</div>
                                <div class="franchise-list" id="franchiseList"></div>
                            </div>

                            <!-- Anime Detail View (Now appears above video player) -->
                            <div class="anime-detail" id="animeDetail">
                                <div class="detail-header" style="position: relative;">
                                    <button id="bookmarkBtn" class="bookmark-btn" style="position: absolute; top: 0; right: 0; z-index: 10;">
                                        🔖
                                    </button>
                                    <img src="" alt="" class="detail-image" id="detailImage">
                                    <div class="detail-info">
                                        <h2 class="detail-title" id="detailTitle"></h2>
                                        <div class="synopsis-genres" id="synopsisGenres"></div>
                                        <div class="detail-meta" id="detailMeta"></div>
                                        <!-- Synopsis inline — no separate box -->
                                        <div class="synopsis-section" id="synopsisSection">
                                            <div class="synopsis-title">Synopsis</div>
                                            <div class="synopsis-content" id="synopsisContent">No synopsis available.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Navigation - Moved outside container but inside body -->
                    <div class="footer-nav">
                        <button class="nav-btn hidden" id="backBtn">
                            <i>&lt;</i>
                            <span>Back</span>
                        </button>
                        <button class="nav-btn active" id="homeBtn">
                            <i>🏠</i>
                            <span>Home</span>
                        </button>
                        <button class="nav-btn" id="historyBtn">
                            <i>📜</i>
                            <span>History</span>
                        </button>
                        <button class="nav-btn" id="profileBtn">
                            <i>👤</i>
                            <span>Profile</span>
                        </button>
                    </div>

                    <script>
                        // ── Theme Management ──────────────────────────────────────────────
                        (function() {
                            const saved = localStorage.getItem('itsukime_theme');
                            if (saved === 'light') {
                                document.documentElement.setAttribute('data-theme', 'light');
                            }
                        })();

                        function getTheme() {
                            return document.documentElement.getAttribute('data-theme') || 'dark';
                        }

                        function setTheme(theme) {
                            if (theme === 'light') {
                                document.documentElement.setAttribute('data-theme', 'light');
                            } else {
                                document.documentElement.removeAttribute('data-theme');
                            }
                            localStorage.setItem('itsukime_theme', theme);
                            document.querySelectorAll('.theme-toggle-option').forEach(el => {
                                el.classList.toggle('active', el.dataset.theme === theme);
                            });
                        }

                        function toggleTheme() {
                            setTheme(getTheme() === 'light' ? 'dark' : 'light');
                        }
                        // ──────────────────────────────────────────────────────────────────

                        const socket = io();
                        let channelNames = <%- JSON.stringify(channelNames || []) %>;
                        let animeMetadata = <%- JSON.stringify(animeMetadata || {}) %>;
                        let synonymMap = <%- JSON.stringify(synonyms || {}) %>;
                        let currentVideos = [];
                        let currentChannel = null;
                        let currentTmdbShowInfo = null;
                        let currentAnimeMetadata = null;
                        let watchHistory = [];
                        let continueWatching = [];
                        let bookmarks = [];

                        // Initialize elements
                        const videoPlayer = document.getElementById('videoPlayer');
                        const searchInput = document.getElementById('searchInput');
                        const dropdown = document.getElementById('dropdown');
                        const currentChannelName = document.getElementById('currentChannelName');
                        const episodeCount = document.getElementById('episodeCount');
                        const episodesGrid = document.getElementById('episodesGrid');
                        const homeGrid = document.getElementById('homeGrid');
                        const historyGrid = document.getElementById('historyGrid');
                        const historyItems = document.getElementById('historyItems');
                        const animeDetail = document.getElementById('animeDetail');
                        const mainContent = document.getElementById('mainContent');
                        const backBtn = document.getElementById('backBtn');
                        const detailImage = document.getElementById('detailImage');
                        const detailTitle = document.getElementById('detailTitle');

                        const synopsisContent = document.getElementById('synopsisContent');
                        const bookmarkBtn = document.getElementById('bookmarkBtn');

                        const homeBtn = document.getElementById('homeBtn');
                        const historyBtn = document.getElementById('historyBtn');
                        const profileBtn = document.getElementById('profileBtn');
                        const clearHistoryBtn = document.getElementById('clearHistoryBtn');

                        // Load watch history from localStorage
                        function loadWatchHistory() {
                            const saved = localStorage.getItem('itsukime_history');
                            if (saved) {
                                watchHistory = JSON.parse(saved);
                                displayWatchHistory();
                            }

                            const savedContinue = localStorage.getItem('itsukime_continue_watching');
                            if (savedContinue) {
                                continueWatching = JSON.parse(savedContinue);
                                displayContinueWatching();
                            }

                            const savedBookmarks = localStorage.getItem('itsukime_bookmarks');
                            if (savedBookmarks) {
                                bookmarks = JSON.parse(savedBookmarks);
                            }
                        }

                        // Save watch history to localStorage
                        function saveWatchHistory() {
                            localStorage.setItem('itsukime_history', JSON.stringify(watchHistory));
                            localStorage.setItem('itsukime_continue_watching', JSON.stringify(continueWatching));
                            localStorage.setItem('itsukime_bookmarks', JSON.stringify(bookmarks));
                        }

                        // Add to watch history
                        function addToHistory(animeName, channelName, episodeNumber, episodeTitle, imageUrl, episodeThumbnail) {
                            const entry = {
                                animeName: animeName,
                                channelName: channelName,
                                episodeNumber: episodeNumber,
                                episodeTitle: episodeTitle,
                                imageUrl: imageUrl,
                                episodeThumbnail: episodeThumbnail || null,
                                timestamp: Date.now(),
                                date: new Date().toLocaleString(),
                                videoTimestamp: 0,
                                duration: 0
                            };

                            // Update Continue Watching
                            continueWatching = continueWatching.filter(e => e.channelName !== channelName);
                            continueWatching.unshift(entry);
                            continueWatching = continueWatching.slice(0, 3);

                            // Remove older entry for same anime/episode from general history
                            watchHistory = watchHistory.filter(e => 
                                !(e.channelName === channelName && e.episodeNumber === episodeNumber)
                            );

                            // Add to beginning of array
                            watchHistory.unshift(entry);

                            // Keep only last 50 entries
                            if (watchHistory.length > 50) {
                                watchHistory = watchHistory.slice(0, 50);
                            }

                            saveWatchHistory();
                            displayWatchHistory();
                            displayContinueWatching();
                        }

                        function updateCurrentProgress() {
                            if (!currentChannel || !videoPlayer.duration) return;

                            const entry = continueWatching.find(e => e.channelName === currentChannel);
                            if (entry) {
                                entry.videoTimestamp = videoPlayer.currentTime;
                                entry.duration = videoPlayer.duration;
                                saveWatchHistory();
                                displayContinueWatching();
                            }
                        }

                        // Periodic progress save
                        setInterval(updateCurrentProgress, 5000);

                        // ── Recently Added Section (horizontal draggable) ─────────────────
                        let serverRecentlyAdded = null;

                        function buildRecentlyAddedSection(serverList) {
                            const section = document.getElementById('recentlyAddedSection');
                            const row = document.getElementById('recentlyAddedRow');
                            if (!section || !row) return;

                            if (serverList) serverRecentlyAdded = serverList;

                            const entries = serverRecentlyAdded;

                            if (!entries || entries.length === 0) {
                                section.classList.add('hidden');
                                return;
                            }

                            section.classList.remove('hidden');
                            row.innerHTML = '';

                            entries.forEach((item) => {
                                const channelName = item.channelName;
                                const meta = animeMetadata[channelName] || item;
                                const card = document.createElement('div');
                                card.className = 'ra-card';

                                const genreTags = (item.genres || []).slice(0, 2)
                                    .map(g => `<span class="genre-tag">${g}</span>`).join('');

                                card.innerHTML = `
                                    <img src="${item.imageUrl || 'https://via.placeholder.com/300x450?text=No+Image'}"
                                         alt="${(item.name || channelName).replace(/"/g, '&quot;')}"
                                         loading="lazy"
                                         onerror="this.src='https://via.placeholder.com/300x450?text=No+Image'">
                                    <div class="ra-info">
                                        <div class="ra-name">${item.name || channelName}</div>
                                        <div class="anime-genres" style="margin-top:0.25rem">${genreTags}</div>
                                    </div>
                                `;

                                card.addEventListener('click', () => {
                                    showAnimeDetail(meta, channelName);
                                });

                                row.appendChild(card);
                            });

                            // Mouse drag-to-scroll
                            let isDown = false, startX = 0, scrollLeft = 0, dragged = false;
                            row.addEventListener('mousedown', (e) => {
                                isDown = true; dragged = false;
                                startX = e.pageX - row.offsetLeft;
                                scrollLeft = row.scrollLeft;
                                row.classList.add('is-dragging');
                            });
                            row.addEventListener('mouseleave', () => { isDown = false; row.classList.remove('is-dragging'); });
                            row.addEventListener('mouseup', () => { isDown = false; row.classList.remove('is-dragging'); });
                            row.addEventListener('mousemove', (e) => {
                                if (!isDown) return;
                                e.preventDefault();
                                const x = e.pageX - row.offsetLeft;
                                const walk = x - startX;
                                if (Math.abs(walk) > 4) dragged = true;
                                row.scrollLeft = scrollLeft - walk;
                            });
                            // Prevent click after drag
                            row.querySelectorAll('.ra-card').forEach(card => {
                                card.addEventListener('click', (e) => { if (dragged) e.stopImmediatePropagation(); }, true);
                            });

                            // "> " scroll button
                            const scrollBtn = document.getElementById('raScrollBtn');
                            if (scrollBtn) {
                                scrollBtn.onclick = () => {
                                    const firstCard = row.querySelector('.ra-card');
                                    if (!firstCard) return;
                                    const cardWidth = firstCard.offsetWidth;
                                    const gap = 12; // 0.75rem gap
                                    row.scrollBy({ left: (cardWidth + gap) * 3, behavior: 'smooth' });
                                };
                            }
                        }

                        function displayContinueWatching() {
                            const continueWatchingGrid = document.getElementById('continueWatchingGrid');
                            if (!continueWatchingGrid) return;

                            if (continueWatching.length === 0 || animeDetail.classList.contains('visible') || mainContent.classList.contains('visible')) {
                                continueWatchingSection.classList.add('hidden');
                                return;
                            }

                            continueWatchingSection.classList.remove('hidden');
                            continueWatchingGrid.innerHTML = '';

                            continueWatching.forEach(entry => {
                                const card = document.createElement('div');
                                card.className = 'cw-card';

                                const progress = entry.duration ? (entry.videoTimestamp / entry.duration) * 100 : 0;
                                const epNum = entry.episodeNumber % 1 !== 0 ? entry.episodeNumber : `EP ${String(entry.episodeNumber).padStart(2, '0')}`;
                                const thumbSrc = entry.episodeThumbnail || entry.imageUrl || 'https://via.placeholder.com/640x360?text=No+Image';

                                card.innerHTML = `
                                    <img src="${thumbSrc}"
                                         alt="${entry.animeName}"
                                         class="cw-thumbnail"
                                         loading="lazy"
                                         onerror="this.src='${entry.imageUrl || 'https://via.placeholder.com/640x360?text=No+Image'}'">
                                    <div class="cw-overlay">
                                        <div class="cw-anime-name">${entry.animeName}</div>
                                        <div class="cw-ep-label">${epNum}${entry.episodeTitle ? ' · ' + entry.episodeTitle : ''}</div>
                                    </div>
                                    <div class="cw-progress-bar-container">
                                        <div class="cw-progress-bar" style="width: ${progress}%"></div>
                                    </div>
                                `;

                                // Lazily resolve TMDB episode thumbnail for old entries missing it
                                if (!entry.episodeThumbnail && entry.channelName) {
                                    const img = card.querySelector('.cw-thumbnail');
                                    fetch(`/api/videos/${encodeURIComponent(entry.channelName)}`)
                                        .then(r => r.ok ? r.json() : null)
                                        .then(data => {
                                            if (!data || !data.videos) return;
                                            const vid = data.videos.find(v => v.episode === entry.episodeNumber);
                                            if (vid && vid.tmdbThumbnail) {
                                                img.src = vid.tmdbThumbnail;
                                                entry.episodeThumbnail = vid.tmdbThumbnail;
                                                saveWatchHistory();
                                            }
                                        })
                                        .catch(() => {});
                                }

                                card.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    const metadata = animeMetadata[entry.channelName];
                                    if (metadata) {
                                        showAnimeDetail(metadata, entry.channelName, entry.episodeNumber);
                                        const seekHandler = () => {
                                            if (entry.videoTimestamp > 0) {
                                                videoPlayer.currentTime = entry.videoTimestamp;
                                            }
                                            videoPlayer.removeEventListener('loadedmetadata', seekHandler);
                                        };
                                        videoPlayer.addEventListener('loadedmetadata', seekHandler);
                                    }
                                });

                                continueWatchingGrid.appendChild(card);
                            });

                            // Mouse drag-to-scroll (attach once)
                            if (!continueWatchingGrid.dataset.dragInit) {
                                continueWatchingGrid.dataset.dragInit = '1';
                                let cwDown = false, cwStartX = 0, cwScrollLeft = 0, cwDragged = false;
                                continueWatchingGrid.addEventListener('mousedown', (e) => {
                                    cwDown = true; cwDragged = false;
                                    cwStartX = e.pageX - continueWatchingGrid.offsetLeft;
                                    cwScrollLeft = continueWatchingGrid.scrollLeft;
                                    continueWatchingGrid.classList.add('is-dragging');
                                });
                                continueWatchingGrid.addEventListener('mouseleave', () => { cwDown = false; continueWatchingGrid.classList.remove('is-dragging'); });
                                continueWatchingGrid.addEventListener('mouseup', () => { cwDown = false; continueWatchingGrid.classList.remove('is-dragging'); });
                                continueWatchingGrid.addEventListener('mousemove', (e) => {
                                    if (!cwDown) return;
                                    e.preventDefault();
                                    const x = e.pageX - continueWatchingGrid.offsetLeft;
                                    const walk = x - cwStartX;
                                    if (Math.abs(walk) > 4) cwDragged = true;
                                    continueWatchingGrid.scrollLeft = cwScrollLeft - walk;
                                });
                                // Prevent click-through after drag (event delegation)
                                continueWatchingGrid.addEventListener('click', (e) => {
                                    if (cwDragged) { e.stopImmediatePropagation(); cwDragged = false; }
                                }, true);
                            }
                        }

                        // Display watch history
                        function displayWatchHistory() {
                            if (!historyItems) return;

                            if (watchHistory.length === 0) {
                                historyItems.innerHTML = '<div class="no-results">No watch history yet</div>';
                                return;
                            }

                            historyItems.innerHTML = '';

                            watchHistory.forEach(entry => {
                                const card = document.createElement('div');
                                card.className = 'history-card';
                                card.dataset.channel = entry.channelName;
                                card.dataset.episode = entry.episodeNumber;

                                // Format timestamp
                                const timestamp = new Date(entry.timestamp);
                                const timeAgo = getTimeAgo(timestamp);

                                card.innerHTML = `
                                    <img src="${entry.imageUrl || 'https://via.placeholder.com/300x450?text=No+Image'}" 
                                         alt="${entry.animeName}" 
                                         class="anime-image"
                                         loading="lazy"
                                         onerror="this.src='https://via.placeholder.com/300x450?text=No+Image'">
                                    <span class="history-timestamp">${timeAgo}</span>
                                    <span class="history-episode">EP ${entry.episodeNumber % 1 !== 0 ? entry.episodeNumber : entry.episodeNumber.toString().padStart(2, '0')}</span>
                                    <div class="anime-info">
                                        <div class="anime-name">${entry.animeName}</div>
                                    </div>
                                `;

                                card.addEventListener('click', () => {
                                    const metadata = animeMetadata[entry.channelName];
                                    if (metadata) {
                                        showAnimeDetail(metadata, entry.channelName, entry.episodeNumber);
                                    } else {
                                        loadChannel(entry.channelName, entry.animeName, entry.episodeNumber);
                                    }
                                });

                                historyItems.appendChild(card);
                            });
                        }

                        // Helper function to get time ago string
                        function getTimeAgo(date) {
                            const seconds = Math.floor((new Date() - date) / 1000);

                            let interval = seconds / 31536000;
                            if (interval > 1) return Math.floor(interval) + 'y';

                            interval = seconds / 2592000;
                            if (interval > 1) return Math.floor(interval) + 'mo';

                            interval = seconds / 86400;
                            if (interval > 1) return Math.floor(interval) + 'd';

                            interval = seconds / 3600;
                            if (interval > 1) return Math.floor(interval) + 'h';

                            interval = seconds / 60;
                            if (interval > 1) return Math.floor(interval) + 'm';

                            return 'now';
                        }

                        // Clear watch history
                        function clearWatchHistory() {
                            if (confirm('Clear watch history?')) {
                                watchHistory = [];
                                continueWatching = [];
                                saveWatchHistory();
                                displayWatchHistory();
                                displayContinueWatching();
                                if (!historyGrid.classList.contains('hidden')) {
                                    showHistory();
                                }
                            }
                        }

                        // Navigation functions
                        let currentVisibleCount = 80;
                        const loadMoreBtn = document.getElementById('loadMoreBtn');
                        const loadMoreContainer = document.getElementById('loadMoreContainer');
                        const continueWatchingSection = document.getElementById('continueWatchingSection');

                        function updateLoadMoreVisibility() {
                            const allCards = document.querySelectorAll('.anime-card[data-index]');
                            const hiddenCards = document.querySelectorAll('.anime-card.hidden-anime[data-index]');
                            if (hiddenCards.length === 0) {
                                loadMoreContainer.style.display = 'none';
                            } else {
                                loadMoreContainer.style.display = 'flex';
                            }
                        }

                        loadMoreBtn.addEventListener('click', () => {
                            const hiddenCards = Array.from(document.querySelectorAll('.anime-card.hidden-anime[data-index]'));
                            const toShow = hiddenCards.slice(0, 100);

                            toShow.forEach(card => {
                                card.classList.remove('hidden-anime');
                                if (!card.classList.contains('fade-in')) {
                                    if (fadeObserver) {
                                        fadeObserver.observe(card);
                                    } else {
                                        card.classList.add('fade-in');
                                    }
                                }
                            });

                            currentVisibleCount += toShow.length;
                            updateLoadMoreVisibility();
                        });

                        // Initialize load more visibility
                        updateLoadMoreVisibility();

                        function showHome() {
                            homeGrid.classList.remove('hidden');
                            historyGrid.classList.add('hidden');
                            animeDetail.classList.remove('visible');
                            mainContent.classList.remove('visible');
                            document.getElementById('franchiseSection')?.classList.remove('visible');
                            updateLoadMoreVisibility();

                            if (continueWatching.length > 0) {
                                continueWatchingSection.classList.remove('hidden');
                                displayContinueWatching();
                            }

                            seasonalSection.classList.remove('hidden');
                            document.getElementById('recentlyAddedTitle').style.display = 'block';
                            buildRecentlyAddedSection();

                            backBtn.classList.add('hidden');
                            homeBtn.classList.add('active');
                            historyBtn.classList.remove('active');
                            profileBtn.classList.remove('active');
                        }

                        function showHistory() {
                            homeGrid.classList.add('hidden');
                            historyGrid.classList.remove('hidden');
                            animeDetail.classList.remove('visible');
                            mainContent.classList.remove('visible');
                            loadMoreContainer.style.display = 'none';
                            continueWatchingSection.classList.add('hidden');
                            seasonalSection.classList.add('hidden');
                            document.getElementById('recentlyAddedSection').classList.add('hidden');
                            document.getElementById('recentlyAddedTitle').style.display = 'none';

                            backBtn.classList.add('hidden');
                            homeBtn.classList.remove('active');
                            historyBtn.classList.add('active');
                            profileBtn.classList.remove('active');

                            displayWatchHistory();
                        }

                        function showProfile() {
                            homeGrid.classList.add('hidden');
                            historyGrid.classList.remove('hidden');
                            animeDetail.classList.remove('visible');
                            mainContent.classList.remove('visible');
                            loadMoreContainer.style.display = 'none';
                            continueWatchingSection.classList.add('hidden');
                            seasonalSection.classList.add('hidden');
                            document.getElementById('recentlyAddedSection').classList.add('hidden');
                            document.getElementById('recentlyAddedTitle').style.display = 'none';

                            backBtn.classList.add('hidden');
                            homeBtn.classList.remove('active');
                            historyBtn.classList.remove('active');
                            profileBtn.classList.add('active');

                            // Show profile view
                            let bookmarkSort = localStorage.getItem('itsukime_bookmark_sort') || 'recent';

                            function buildBookmarksHTML(sort) {
                                if (bookmarks.length === 0) {
                                    return '<p style="color: #666; margin-top: 1rem;">No bookmarked anime yet</p>';
                                }
                                const sorted = [...bookmarks];
                                if (sort === 'az') sorted.sort((a, b) => a.name.localeCompare(b.name));
                                else if (sort === 'za') sorted.sort((a, b) => b.name.localeCompare(a.name));
                                else sorted.sort((a, b) => (b.addedAt || 0) - (a.addedAt || 0));

                                let html = '<div class="history-grid visible" style="margin-top: 1rem; grid-template-columns: repeat(3, 1fr) !important;">';
                                sorted.forEach(anime => {
                                    html += `
                                        <div class="anime-card" onclick="showAnimeDetailByChannel('${anime.channelName}')">
                                            <img src="${anime.imageUrl}" alt="${anime.name}" class="anime-image">
                                            <div class="anime-info">
                                                <div class="anime-name">${anime.name}</div>
                                            </div>
                                        </div>
                                    `;
                                });
                                html += '</div>';
                                return html;
                            }

                            const cur = getTheme();

                            historyItems.innerHTML = `
                                <div class="profile-view">
                                    <div class="profile-avatar">👤</div>
                                    <h3 class="profile-title">Itsukime Viewer</h3>
                                    <p style="color: var(--text-dim); margin-bottom: 1rem;">Your personal anime streaming</p>
                                    <div class="theme-toggle">
                                        <div class="theme-toggle-option ${cur === 'light' ? 'active' : ''}" data-theme="light" onclick="setTheme('light')">☀️ Light</div>
                                        <div class="theme-toggle-option ${cur === 'dark' ? 'active' : ''}" data-theme="dark" onclick="setTheme('dark')">🌙 Dark</div>
                                    </div>
                                    <div class="profile-stats" style="margin-top: 2rem;">
                                        <p>Episodes watched: <span>${watchHistory.length}</span></p>
                                        <p style="margin-top: 0.5rem;">Member since: <span>${new Date().toLocaleDateString()}</span></p>
                                    </div>
                                    <div style="text-align: left; margin-top: 2rem;">
                                        <div style="display:flex; align-items:center; justify-content:space-between; border-bottom: 1px solid var(--border-accent); padding-bottom: 0.5rem; margin-bottom: 0.25rem;">
                                            <h4 style="color: var(--accent-soft); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin:0;">Bookmarked Anime</h4>
                                            <select id="bookmarkSortSelect" style="background:var(--bg-card);color:var(--text-dim);border:1px solid var(--border-accent);border-radius:6px;padding:0.2rem 0.4rem;font-size:0.72rem;font-weight:700;cursor:pointer;">
                                                <option value="recent" ${bookmarkSort==='recent'?'selected':''}>Recently Added</option>
                                                <option value="az"     ${bookmarkSort==='az'?'selected':''}>A → Z</option>
                                                <option value="za"     ${bookmarkSort==='za'?'selected':''}>Z → A</option>
                                            </select>
                                        </div>
                                        <div id="bookmarksContainer">${buildBookmarksHTML(bookmarkSort)}</div>
                                    </div>

                                    <div class="profile-footer">
