                        // Load channel videos
                        async function loadChannel(channelName, displayName, episodeToPlay = 1) {
                            try {
                                const response = await fetch(`/api/channel/${encodeURIComponent(channelName)}`);
                                const data = await response.json();

                                if (!response.ok || !data.videos) {
                                    console.warn(`Channel not found or no videos: "${channelName}"`, data.error || '');
                                    return;
                                }

                                currentVideos = data.videos;
                                currentChannel = channelName;
                                currentTmdbShowInfo = data.tmdbShowInfo || null;

                                // Format display name if not provided
                                const finalDisplayName = displayName || channelName.replace(/-/g, ' ')
                                    .split(' ')
                                    .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
                                    .join(' ');

                                homeGrid.classList.add('hidden');
                                historyGrid.classList.add('hidden');
                                document.getElementById('recentlyAddedSection').classList.add('hidden');
                                document.getElementById('recentlyAddedTitle').style.display = 'none';
                                loadMoreContainer.style.display = 'none';
                                seasonalSection.classList.add('hidden');

                                // Make main content visible
                                mainContent.classList.add('visible');
                                if (continueWatchingSection) {
                                    continueWatchingSection.classList.add('hidden');
                                }

                                // Update UI
                                currentChannelName.textContent = finalDisplayName;
                                episodeCount.textContent = `${currentVideos.length}`;

                                const RANGE_SIZE = 100;
                                if (episodeToPlay > 1 && currentVideos.length > RANGE_SIZE) {
                                    const epIndex = currentVideos.findIndex(v => v.episode === episodeToPlay);
                                    currentEpisodeRange = epIndex >= 0 ? Math.floor(epIndex / RANGE_SIZE) : 0;
                                } else {
                                    currentEpisodeRange = 0;
                                }
                                displayEpisodes(currentVideos);

                                // Load specified episode or first video
                                if (currentVideos.length > 0) {
                                    const videoToPlay = currentVideos.find(v => v.episode === episodeToPlay) || currentVideos[0];
                                    playVideo(videoToPlay, finalDisplayName);
                                }

                                mainContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
                            } catch (error) {
                                console.error(`Error loading channel "${channelName}":`, error.message || error);
                            }
                        }

                        let currentEpisodeRange = 0;

                        function displayEpisodes(videos) {
                            const rangesContainer = document.getElementById('episodeRanges');
                            rangesContainer.innerHTML = '';
                            episodesGrid.innerHTML = '';

                            // Deduplicate by episode number — keep first occurrence of each ep
                            const seenEps = new Set();
                            videos = videos.filter(v => {
                                const key = v.episode != null ? String(v.episode) : null;
                                if (key === null) return true;
                                if (seenEps.has(key)) return false;
                                seenEps.add(key);
                                return true;
                            });

                            const RANGE_SIZE = 100;
                            const totalEpisodes = videos.length;

                            if (totalEpisodes > RANGE_SIZE) {
                                const numRanges = Math.ceil(totalEpisodes / RANGE_SIZE);
                                for (let i = 0; i < numRanges; i++) {
                                    const start = i * RANGE_SIZE + 1;
                                    const end = Math.min((i + 1) * RANGE_SIZE, totalEpisodes);
                                    const rangeBtn = document.createElement('button');
                                    rangeBtn.className = 'episode-range-btn' + (i === currentEpisodeRange ? ' active' : '');
                                    rangeBtn.textContent = start + '-' + end;
                                    rangeBtn.addEventListener('click', () => {
                                        currentEpisodeRange = i;
                                        displayEpisodes(videos);
                                    });
                                    rangesContainer.appendChild(rangeBtn);
                                }
                            } else {
                                currentEpisodeRange = 0;
                            }

                            const startIdx = currentEpisodeRange * RANGE_SIZE;
                            const endIdx = Math.min(startIdx + RANGE_SIZE, totalEpisodes);
                            const visibleVideos = videos.slice(startIdx, endIdx);

                            const hasAnyTmdbEpData = visibleVideos.some(v => v.tmdbThumbnail || v.tmdbTitle);
                            episodesGrid.classList.toggle('has-thumbnails', hasAnyTmdbEpData);

                            visibleVideos.forEach((video, index) => {
                                const episodeNumber = video.episode || (startIdx + index + 1);
                                const btn = document.createElement('button');
                                const isDecimal = episodeNumber % 1 !== 0;
                                const epLabel = isDecimal ? episodeNumber.toString() : episodeNumber.toString().padStart(2, '0');

                                if (hasAnyTmdbEpData) {
                                    btn.className = 'episode-btn has-thumb';
                                    const descText = video.tmdbDescription || '';
                                    const truncDesc = descText.length > 120 ? descText.substring(0, 120) + '...' : descText;
                                    const thumbHtml = video.tmdbThumbnail
                                        ? `<img class="ep-thumb" src="${video.tmdbThumbnail}" alt="Ep ${epLabel}" loading="lazy">`
                                        : `<div class="ep-thumb ep-thumb-blank"></div>`;
                                    const descHtml = truncDesc || 'No description available for this episode';
                                    btn.innerHTML = `${thumbHtml}<div class="ep-info"><span class="ep-number">Episode ${epLabel}</span>${video.tmdbTitle ? `<span class="ep-title">${video.tmdbTitle}</span>` : ''}<span class="ep-desc">${descHtml}</span></div>`;
                                } else {
                                    btn.className = 'episode-btn';
                                    btn.textContent = epLabel;
                                }

                                btn.dataset.episode = episodeNumber;
                                btn.addEventListener('click', () => playVideo(video, currentChannelName.textContent));

                                episodesGrid.appendChild(btn);
                            });
                        }

                        function playVideo(video, displayName) {
                            // Update video hover overlay
                            const titleEl = document.getElementById('videoTitleText');
                            const epTitleEl = document.getElementById('videoEpTitle');
                            if (titleEl) {
                                const epLabel = video.episode % 1 !== 0 ? video.episode : `EP ${String(video.episode || 1).padStart(2, '0')}`;
                                titleEl.textContent = `${displayName || currentChannelName.textContent} — ${epLabel}`;
                            }
                            if (epTitleEl) {
                                if (video.tmdbTitle) {
                                    epTitleEl.textContent = video.tmdbTitle;
                                    epTitleEl.classList.add('visible');
                                } else {
                                    epTitleEl.textContent = '';
                                    epTitleEl.classList.remove('visible');
                                }
                            }

                            // Update video player
                            videoPlayer.src = video.url;
                            videoPlayer.load();

                            // Add event listener to start from saved timestamp if applicable
                            const entry = continueWatching.find(e => e.channelName === currentChannel && e.episodeNumber === video.episode);
                            if (entry && entry.videoTimestamp > 0) {
                                const seekHandler = () => {
                                    videoPlayer.currentTime = entry.videoTimestamp;
                                    videoPlayer.removeEventListener('loadedmetadata', seekHandler);
                                };
                                videoPlayer.addEventListener('loadedmetadata', seekHandler);
                            }

                            videoPlayer.play().catch(e => console.warn('Autoplay blocked:', e.message));

                            document.querySelectorAll('.episode-btn').forEach((btn) => {
                                btn.classList.remove('active');
                                if (parseFloat(btn.dataset.episode) === (video.episode || 1)) {
                                    btn.classList.add('active');
                                    setTimeout(() => {
                                        btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                                    }, 400);
                                }
                            });

                            // Add to watch history
                            const metadata = animeMetadata[currentChannel];
                            if (metadata) {
                                addToHistory(
                                    metadata.name,
                                    currentChannel,
                                    video.episode || 1,
                                    video.title,
                                    metadata.imageUrl,
                                    video.tmdbThumbnail || video.thumbnail || null
                                );
                            }

                            // Emit to socket
                            socket.emit('play-video', {
                                channel: video.channelName,
                                title: video.title,
                                episode: video.episode
                            });
                        }

                        // Navigation event listeners
                        homeBtn.addEventListener('click', showHome);
                        historyBtn.addEventListener('click', showHistory);
                        profileBtn.addEventListener('click', showProfile);
                        clearHistoryBtn.addEventListener('click', clearWatchHistory);

                        // Socket.io updates
                        let seasonalRebuildTimer = null;
                        function debouncedSeasonalRebuild() {
                            if (seasonalRebuildTimer) return;
                            seasonalRebuildTimer = setTimeout(() => {
                                buildSeasonalCards();
                                updateSeasonalPosition();
                                seasonalRebuildTimer = null;
                            }, 500);
                        }

                        socket.on('library-update', (data) => {
                            if (data.channels && data.channels.length > 0) {
                                console.log('📡 Library updated:', data.channels.length, 'channels');
                                channelNames = data.channels;
                                debouncedSeasonalRebuild();
                            }
                            if (data.recentlyAdded) {
                                if (!homeGrid.classList.contains('hidden')) {
                                    buildRecentlyAddedSection(data.recentlyAdded);
                                } else {
                                    serverRecentlyAdded = data.recentlyAdded;
                                }
                            }
                        });

                        // Build home grid cards dynamically if the page loaded before metadata was ready
                        function buildHomeGridIfEmpty() {
                            const grid = document.getElementById('homeGrid');
                            if (!grid || grid.querySelector('.anime-card[data-index]')) return;
                            const entries = Object.entries(animeMetadata);
                            if (entries.length === 0) return;
                            grid.innerHTML = '';
                            entries.forEach(([channelName, metadata], index) => {
                                const card = document.createElement('div');
                                card.className = 'anime-card' + (index >= 80 ? ' hidden-anime' : '');
                                card.dataset.channel = channelName;
                                card.dataset.index = String(index);
                                card.dataset.genres = (metadata.genres || []).join(',');
                                const genreTags = (metadata.genres || []).slice(0, 2)
                                    .map(g => `<span class="genre-tag">${g}</span>`).join('');
                                card.innerHTML = `
                                    <img src="${metadata.imageUrl || ''}" alt="${(metadata.name || '').replace(/"/g, '&quot;')}" class="anime-image" loading="${index < 20 ? 'eager' : 'lazy'}" onerror="this.src='https://via.placeholder.com/300x450?text=No+Image'">
                                    <div class="anime-info">
                                        <div class="anime-name">${metadata.name || channelName}</div>
                                        <div class="anime-genres">${genreTags}</div>
                                    </div>`;
                                card.addEventListener('click', () => {
                                    const meta = animeMetadata[channelName];
                                    if (meta) showAnimeDetail(meta, channelName);
                                });
                                if (index < 80) {
                                    if (fadeObserver) {
                                        fadeObserver.observe(card);
                                    } else {
                                        card.classList.add('fade-in');
                                    }
                                }
                                grid.appendChild(card);
                            });
                            updateLoadMoreVisibility();
                        }

                        socket.on('metadata-update', (data) => {
                            console.log('📚 Metadata updated');
                            if (data.metadata) {
                                animeMetadata = data.metadata;
                                buildHomeGridIfEmpty();
                                updateCardGenres();
                                debouncedSeasonalRebuild();
                                rebuildGenreFilter();
                                // Rebuild recently added if we're on home view
                                if (!homeGrid.classList.contains('hidden')) {
                                    buildRecentlyAddedSection();
                                }
                            }
                            if (data.synonyms) {
                                synonymMap = data.synonyms;
                            }
                        });

                        // Keyboard shortcuts
                        document.addEventListener('keydown', (e) => {
                            if (e.key === 'Escape') {
                                dropdown.classList.remove('active');
                            }

                            if (e.key === '/' && !searchInput.matches(':focus')) {
                                e.preventDefault();
                                searchInput.focus();
                            }
                        });

                        // Seasonal Anime
                        const seasonalAnime = [
                            'The Klutzy Class Monitor and the Girl with the Short Skirt',
                            'Re:ZERO: Starting Life in Another World Season 4',
                            'Petals of Reincarnation',
                            'Dr. Stone: Science Future - Part III', 'Haibara’s Teenage New Game+',
                            'Classroom of the Elite 4th Season'

                        ];
                        const seasonalSection = document.getElementById('seasonalSection');
                        const seasonalTrack = document.getElementById('seasonalTrack');
                        const seasonalPrev = document.getElementById('seasonalPrev');
                        const seasonalNext = document.getElementById('seasonalNext');
                        let seasonalIndex = 0;

                        function titleToChannelName(title) {
                            if (!title || typeof title !== 'string') return '';
                            return title
                                .toLowerCase()
                                .replace(/'/g, '')
                                .replace(/[^a-z0-9\s]/g, ' ')
                                .trim()
                                .replace(/\s+/g, '-');
                        }

                        function findSeasonalChannel(title) {
                            const normalized = titleToChannelName(title);
                            const alpha = normalized.replace(/[^a-z0-9]/g, '');

                            let channelKey = null;
                            if (channelNames.includes(normalized)) {
                                channelKey = normalized;
                            } else {
                                let bestDiff = Infinity;
                                for (const key of channelNames) {
                                    const keyAlpha = key.replace(/[^a-z0-9]/g, '');
                                    if (keyAlpha === alpha) { channelKey = key; break; }
                                    if (keyAlpha.includes(alpha) || alpha.includes(keyAlpha)) {
                                        const diff = Math.abs(keyAlpha.length - alpha.length);
                                        if (diff < bestDiff) { bestDiff = diff; channelKey = key; }
                                    }
                                }
                            }

                            let meta = null;
                            if (channelKey && animeMetadata[channelKey]) {
                                meta = animeMetadata[channelKey];
                            }
                            if (!meta) {
                                let bestDiff = Infinity;
                                for (const [key, m] of Object.entries(animeMetadata)) {
                                    const keyAlpha = key.replace(/[^a-z0-9]/g, '');
                                    if (keyAlpha.includes(alpha) || alpha.includes(keyAlpha)) {
                                        const diff = Math.abs(keyAlpha.length - alpha.length);
                                        if (diff < bestDiff) { bestDiff = diff; meta = m; }
                                    }
                                }
                            }

                            return { channelKey: channelKey || normalized, meta };
                        }

                        function buildSeasonalCards() {
                            seasonalTrack.innerHTML = '';
                            seasonalAnime.forEach(title => {
                                const found = findSeasonalChannel(title);
                                const imageUrl = found.meta ? found.meta.imageUrl : 'https://via.placeholder.com/640x360?text=' + encodeURIComponent(title);
                                const displayName = title;
                                const channelName = found.channelKey;

                                const card = document.createElement('div');
                                card.className = 'seasonal-card';
                                card.innerHTML = `
                                    <img src="${imageUrl}" alt="${displayName}" class="seasonal-card-image" loading="lazy" onerror="this.src='https://via.placeholder.com/640x360?text=No+Image'">
                                    <div class="seasonal-card-overlay">
                                        <span class="seasonal-card-name">${displayName}</span>
                                        <button class="seasonal-watch-btn" data-channel="${channelName}">Start Watching</button>
                                    </div>
                                `;

                                function openSeasonal() {
                                    const baseMeta = animeMetadata[channelName] || found.meta;
                                    if (baseMeta) {
                                        const overriddenMeta = Object.assign({}, baseMeta, { name: displayName });
                                        showAnimeDetail(overriddenMeta, channelName);
                                    } else {
                                        loadChannel(channelName, displayName);
                                    }
                                }

                                card.querySelector('.seasonal-watch-btn').addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    openSeasonal();
                                });

                                card.addEventListener('click', () => {
                                    openSeasonal();
                                });

                                seasonalTrack.appendChild(card);
                            });
                        }

                        function getSeasonalCardsPerView() {
                            if (window.innerWidth >= 1024) return 3;
                            if (window.innerWidth >= 769) return 2;
                            return 1;
                        }

                        function updateSeasonalPosition() {
                            const perView = getSeasonalCardsPerView();
                            const maxIndex = Math.max(0, seasonalAnime.length - perView);
                            if (seasonalIndex > maxIndex) seasonalIndex = maxIndex;
                            if (seasonalIndex < 0) seasonalIndex = 0;
                            const gap = parseFloat(getComputedStyle(seasonalTrack).gap) || 16;
                            const cards = seasonalTrack.children;
                            if (cards.length > 0 && seasonalIndex > 0) {
                                const offset = cards[seasonalIndex].offsetLeft - cards[0].offsetLeft;
                                seasonalTrack.style.transform = `translateX(-${offset}px)`;
                            } else {
                                seasonalTrack.style.transform = 'translateX(0)';
                            }
                            seasonalPrev.style.opacity = seasonalIndex <= 0 ? '0.3' : '1';
                            seasonalPrev.style.pointerEvents = seasonalIndex <= 0 ? 'none' : 'auto';
                            seasonalNext.style.opacity = seasonalIndex >= maxIndex ? '0.3' : '1';
                            seasonalNext.style.pointerEvents = seasonalIndex >= maxIndex ? 'none' : 'auto';
                        }

                        let seasonalAutoTimer = null;

                        function startSeasonalAuto() {
                            stopSeasonalAuto();
                            seasonalAutoTimer = setInterval(() => {
                                const perView = getSeasonalCardsPerView();
                                const maxIndex = Math.max(0, seasonalAnime.length - perView);
                                if (seasonalIndex >= maxIndex) {
                                    seasonalIndex = 0;
                                } else {
                                    seasonalIndex++;
                                }
                                updateSeasonalPosition();
                            }, 6000);
                        }

                        function stopSeasonalAuto() {
                            if (seasonalAutoTimer) {
                                clearInterval(seasonalAutoTimer);
                                seasonalAutoTimer = null;
                            }
                        }

                        seasonalPrev.addEventListener('click', () => {
                            seasonalIndex--;
                            updateSeasonalPosition();
                            startSeasonalAuto();
                        });

                        seasonalNext.addEventListener('click', () => {
                            seasonalIndex++;
                            updateSeasonalPosition();
                            startSeasonalAuto();
                        });

                        window.addEventListener('resize', updateSeasonalPosition);

                        buildSeasonalCards();
                        updateSeasonalPosition();
                        startSeasonalAuto();

                        // Initialize
                        loadWatchHistory();
                        buildRecentlyAddedSection();

                        // ── Genre Filter Bar ─────────────────────────────────────────────
                        let activeGenre = 'All';

                        // Stamp each card's data-genres from the live metadata object
                        function updateCardGenres() {
                            document.querySelectorAll('#homeGrid .anime-card[data-channel]').forEach(card => {
                                const meta = animeMetadata[card.dataset.channel];
                                if (meta && meta.genres && meta.genres.length > 0) {
                                    card.dataset.genres = meta.genres.join(',');
                                }
                            });
                        }

                        function filterByGenre(genre) {
                            document.querySelectorAll('#homeGrid .anime-card').forEach(card => {
                                if (genre === 'All') {
                                    card.classList.remove('genre-hidden');
                                    // Restore pagination: re-hide cards beyond the current visible count
                                    const idx = parseInt(card.dataset.index) || 0;
                                    if (idx >= currentVisibleCount) {
                                        card.classList.add('hidden-anime');
                                    }
                                } else {
                                    const cardGenres = (card.dataset.genres || '').split(',').map(g => g.trim()).filter(Boolean);
                                    const isMatch = cardGenres.includes(genre);
                                    card.classList.toggle('genre-hidden', !isMatch);
                                    if (isMatch) {
                                        // Show ALL matching cards regardless of pagination
                                        card.classList.remove('hidden-anime');
                                    }
                                }
                            });
                            // Hide Load More when a genre is active (all matches already visible)
                            if (loadMoreContainer) {
                                if (genre === 'All') {
                                    updateLoadMoreVisibility();
                                } else {
                                    loadMoreContainer.style.display = 'none';
                                }
                            }
                        }

                        function rebuildGenreFilter() {
                            const bar = document.getElementById('genreFilterBar');
                            if (!bar) return;

                            // Collect genres from all card data-genres attributes (set by updateCardGenres)
                            const allGenres = new Set();
                            document.querySelectorAll('#homeGrid .anime-card[data-channel]').forEach(card => {
                                (card.dataset.genres || '').split(',').forEach(g => {
                                    const t = g.trim();
                                    if (t && t !== '+') allGenres.add(t);
                                });
                            });

                            if (allGenres.size === 0) return;

                            bar.innerHTML = '';
                            const genres = ['All', ...Array.from(allGenres).sort()];

                            genres.forEach(genre => {
                                const chip = document.createElement('div');
                                chip.className = 'genre-filter-chip' + (genre === activeGenre ? ' active' : '');
                                chip.textContent = genre;
                                chip.addEventListener('click', () => {
                                    activeGenre = genre;
                                    bar.querySelectorAll('.genre-filter-chip').forEach(c => c.classList.remove('active'));
                                    chip.classList.add('active');
                                    filterByGenre(genre);
                                    const fb = document.getElementById('filterBtn');
                                    if (fb) fb.classList.toggle('genre-active', genre !== 'All');
                                });
                                bar.appendChild(chip);
                            });

                            if (activeGenre !== 'All') filterByGenre(activeGenre);
                        }

                        rebuildGenreFilter();

                        // ── Filter button toggle ──────────────────────────────────────────
                        (function() {
                            const filterBtn        = document.getElementById('filterBtn');
                            const genreBar         = document.getElementById('genreFilterBar');
                            const seasonalSection  = document.getElementById('seasonalSection');
                            const continueSection  = document.getElementById('continueWatchingSection');
                            const recentTitle      = document.getElementById('recentlyAddedTitle');
                            const recentSection    = document.getElementById('recentlyAddedSection');
                            const homeGridEl       = document.getElementById('homeGrid');
                            const loadMoreEl       = document.getElementById('loadMoreContainer');
                            const containerEl      = seasonalSection && seasonalSection.parentNode;

                            if (!filterBtn || !genreBar) return;

                            function moveRecentAboveSeasonal() {
                                if (!containerEl || !seasonalSection) return;
                                if (recentSection) containerEl.insertBefore(recentSection, seasonalSection);
                                containerEl.insertBefore(recentTitle, seasonalSection);
                                containerEl.insertBefore(homeGridEl, seasonalSection);
                                containerEl.insertBefore(loadMoreEl, seasonalSection);
                            }

                            function moveRecentBelowSeasonal() {
                                if (!containerEl) return;
                                // Insert after continueWatchingSection (or after seasonalSection if not present)
                                const anchor = continueSection ? continueSection.nextSibling : seasonalSection.nextSibling;
                                if (recentSection) containerEl.insertBefore(recentSection, anchor);
                                containerEl.insertBefore(recentTitle, anchor);
                                containerEl.insertBefore(homeGridEl, anchor);
                                containerEl.insertBefore(loadMoreEl, anchor);
                            }

                            filterBtn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                const open = genreBar.classList.toggle('expanded');
                                filterBtn.classList.toggle('active', open);
                                if (open) {
                                    moveRecentAboveSeasonal();
                                } else {
                                    moveRecentBelowSeasonal();
                                }
                            });

                            document.addEventListener('click', (e) => {
                                if (!genreBar.contains(e.target) && e.target !== filterBtn && !filterBtn.contains(e.target)) {
                                    if (genreBar.classList.contains('expanded')) {
                                        genreBar.classList.remove('expanded');
                                        filterBtn.classList.remove('active');
                                        moveRecentBelowSeasonal();
                                    }
                                }
                            });
                        })();

                        // Save progress when the page is unloaded
                        window.addEventListener('beforeunload', updateCurrentProgress);

                        // ── Custom Video Player ───────────────────────────────────────────────
                        (function() {
                            const vid       = document.getElementById('videoPlayer');
                            const container = vid.closest('.video-player-container');
                            const playBtn   = document.getElementById('ctrlPlayBtn');
                            const progWrap  = document.getElementById('ctrlProgressWrapper');
                            const progFill  = document.getElementById('ctrlProgressFill');
                            const progThumb = document.getElementById('ctrlProgressThumb');
                            const timeEl    = document.getElementById('ctrlTime');
                            const muteBtn   = document.getElementById('ctrlMuteBtn');
                            const volSlider = document.getElementById('ctrlVolumeSlider');
                            const fsBtn     = document.getElementById('ctrlFsBtn');

                            function fmt(s) {
                                if (!s || isNaN(s)) return '0:00';
                                const m = Math.floor(s / 60), sec = Math.floor(s % 60);
                                return `${m}:${sec.toString().padStart(2, '0')}`;
                            }

                            function syncProgress() {
                                if (!vid.duration || dragging) return;
                                const pct = (vid.currentTime / vid.duration) * 100;
                                progFill.style.width = pct + '%';
                                progThumb.style.left = pct + '%';
                                timeEl.textContent = `${fmt(vid.currentTime)} / ${fmt(vid.duration)}`;
                            }

                            function setPaused(isPaused) {
                                playBtn.textContent = isPaused ? '▶' : '⏸';
                                container.classList.toggle('paused', isPaused);
                            }

                            vid.addEventListener('timeupdate', syncProgress);
                            vid.addEventListener('loadedmetadata', () => {
                                syncProgress();
                                timeEl.textContent = `0:00 / ${fmt(vid.duration)}`;
                            });
                            vid.addEventListener('play',  () => { setPaused(false); showControls(); });
                            vid.addEventListener('pause', () => { setPaused(true);  showControls(); });
                            vid.addEventListener('ended', () => setPaused(true));

                            // ── Auto-hide controls on touch ───────────────────────────────
                            let hideTimer = null;
                            function showControls() {
                                container.classList.add('touch-active');
                                clearTimeout(hideTimer);
                                if (!vid.paused || isFs()) {
                                    hideTimer = setTimeout(() => container.classList.remove('touch-active'), 4000);
                                }
                            }
                            container.addEventListener('touchstart', showControls, { passive: true });
                            container.addEventListener('mousemove',  showControls);

                            // ── Play/Pause (click for desktop) ────────────────────────────
                            playBtn.addEventListener('click', () => { vid.paused ? vid.play() : vid.pause(); });

                            // ── Double-tap to seek (mobile) ───────────────────────────────
                            let lastTapTime = 0, lastTapX = 0, singleTapTimer = null, touchHandled = false;

                            function flashSeek(seconds, x) {
                                const el = document.createElement('div');
                                el.className = 'seek-flash';
                                el.textContent = `${seconds > 0 ? '+' : ''}${seconds}s`;
                                el.style.left  = x < container.getBoundingClientRect().left + container.offsetWidth / 2 ? '20%' : 'auto';
                                el.style.right = x < container.getBoundingClientRect().left + container.offsetWidth / 2 ? 'auto' : '20%';
                                container.appendChild(el);
                                setTimeout(() => el.remove(), 800);
                            }

                            vid.addEventListener('touchend', e => {
                                e.preventDefault();
                                touchHandled = true;
                                const now   = Date.now();
                                const touch = e.changedTouches[0];
                                const x     = touch.clientX;
                                const dt    = now - lastTapTime;

                                showControls();

                                if (dt < 300 && Math.abs(x - lastTapX) < 80) {
                                    clearTimeout(singleTapTimer);
                                    lastTapTime = 0;
                                    const rect = vid.getBoundingClientRect();
                                    if (x < rect.left + rect.width / 2) {
                                        vid.currentTime = Math.max(0, vid.currentTime - 10);
                                        flashSeek(-10, x);
                                    } else {
                                        vid.currentTime = Math.min(vid.duration || 0, vid.currentTime + 10);
                                        flashSeek(+10, x);
                                    }
                                } else {
                                    lastTapTime = now;
                                    lastTapX   = x;
                                    singleTapTimer = setTimeout(() => {
                                        if (container.classList.contains('touch-active')) {
                                            clearTimeout(hideTimer);
                                            container.classList.remove('touch-active');
                                        } else {
                                            showControls();
                                        }
                                    }, 300);
                                }
                            });

                            vid.addEventListener('click', e => {
                                if (touchHandled) { touchHandled = false; return; }
                                vid.paused ? vid.play() : vid.pause();
                                showControls();
                            });

                            // ── Seek bar ──────────────────────────────────────────────────
                            let dragging    = false;
                            let pendingSeek = null;
                            let rafPending  = false;

                            function applyVisual(pct) {
                                const p = pct * 100;
                                progFill.style.width = p + '%';
                                progThumb.style.left = p + '%';
                                if (vid.duration) timeEl.textContent = `${fmt(pct * vid.duration)} / ${fmt(vid.duration)}`;
                            }

                            function scheduleVideoSeek(pct) {
                                pendingSeek = pct;
                                if (!rafPending) {
                                    rafPending = true;
                                    requestAnimationFrame(() => {
                                        if (pendingSeek !== null && vid.duration) {
                                            vid.currentTime = pendingSeek * vid.duration;
                                        }
                                        pendingSeek = null;
                                        rafPending  = false;
                                    });
                                }
                            }

                            function seekTo(clientX) {
                                const rect = progWrap.getBoundingClientRect();
                                const pct  = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
                                applyVisual(pct);
                                scheduleVideoSeek(pct);
                            }

                            function startDrag(clientX) {
                                dragging = true;
                                progWrap.classList.add('dragging');
                                seekTo(clientX);
                            }

                            function endDrag() {
                                if (!dragging) return;
                                dragging = false;
                                progWrap.classList.remove('dragging');
                                if (pendingSeek !== null && vid.duration) {
                                    vid.currentTime = pendingSeek * vid.duration;
                                    pendingSeek = null;
                                }
                            }

                            progWrap.addEventListener('mousedown', e => { e.preventDefault(); startDrag(e.clientX); });
                            window.addEventListener('mousemove',   e => { if (dragging) seekTo(e.clientX); });
                            window.addEventListener('mouseup',     () => endDrag());
                            progWrap.addEventListener('touchstart', e => { startDrag(e.touches[0].clientX); }, { passive: true });
                            window.addEventListener('touchmove',    e => { if (dragging) seekTo(e.touches[0].clientX); }, { passive: true });
                            window.addEventListener('touchend',     () => endDrag());

                            // ── Volume ────────────────────────────────────────────────────
                            (function() {
                                const saved = parseFloat(localStorage.getItem('itsukime_volume'));
                                if (!isNaN(saved)) { vid.volume = saved; volSlider.value = saved; }
                            })();

                            muteBtn.addEventListener('click', () => {
                                vid.muted = !vid.muted;
                                muteBtn.textContent = vid.muted ? '🔇' : '🔊';
                                if (!vid.muted) volSlider.value = vid.volume;
                            });
                            volSlider.addEventListener('input', () => {
                                vid.volume = parseFloat(volSlider.value);
                                vid.muted  = vid.volume === 0;
                                muteBtn.textContent = vid.muted ? '🔇' : '🔊';
                                localStorage.setItem('itsukime_volume', volSlider.value);
                            });

                            // ── Playback Speed ────────────────────────────────────────────
                            const speedBtn   = document.getElementById('ctrlSpeedBtn');
                            const speedPopup = document.getElementById('speedPopup');

                            speedBtn.addEventListener('click', e => {
                                e.stopPropagation();
                                speedPopup.classList.toggle('open');
                            });

                            speedPopup.querySelectorAll('.speed-option').forEach(opt => {
                                opt.addEventListener('click', e => {
                                    e.stopPropagation();
                                    const speed = parseFloat(opt.dataset.speed);
                                    vid.playbackRate = speed;
                                    speedBtn.textContent = speed === 1 ? '1×' : speed + '×';
                                    speedPopup.querySelectorAll('.speed-option').forEach(o => o.classList.remove('active'));
                                    opt.classList.add('active');
                                    speedPopup.classList.remove('open');
                                });
                            });

                            document.addEventListener('click', () => {
                                speedPopup.classList.remove('open');
                                downloadPopup.classList.remove('open');
                            });

                            // ── Download ──────────────────────────────────────────────────
                            const downloadBtn  = document.getElementById('ctrlDownloadBtn');
                            const downloadPopup = document.getElementById('downloadPopup');
                            const downloadLink  = document.getElementById('downloadLink');

                            downloadBtn.addEventListener('click', e => {
                                e.stopPropagation();
                                const src = vid.src;
                                if (!src) return;
                                downloadLink.href = src;
                                downloadLink.download = (currentChannel || 'episode') + '.mp4';
                                downloadPopup.classList.toggle('open');
                            });

                            downloadLink.addEventListener('click', e => {
                                e.stopPropagation();
                                downloadPopup.classList.remove('open');
                            });

                            // ── Fullscreen (with iOS & webkit fallbacks) ──────────────────
                            function isFs() {
                                return !!(document.fullscreenElement || document.webkitFullscreenElement);
                            }
                            function lockLandscape() {
                                try {
                                    if (screen.orientation && screen.orientation.lock) {
                                        screen.orientation.lock('landscape').catch(() => {});
                                    }
                                } catch(e) {}
                            }
                            function unlockOrientation() {
                                try {
                                    if (screen.orientation && screen.orientation.unlock) screen.orientation.unlock();
                                } catch(e) {}
                            }
                            function enterFs() {
                                if (container.requestFullscreen)            container.requestFullscreen().then(() => { lockLandscape(); showControls(); }).catch(() => {});
                                else if (container.webkitRequestFullscreen) { container.webkitRequestFullscreen(); lockLandscape(); showControls(); }
                                else if (vid.webkitEnterFullscreen)         vid.webkitEnterFullscreen();
                            }
                            function exitFs() {
                                if (document.exitFullscreen)            document.exitFullscreen();
                                else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
                            }
                            function updateFsIcon() {
                                const inFs = isFs();
                                fsBtn.textContent = inFs ? '🗗' : '⛶';
                                if (!inFs) unlockOrientation();
                            }
                            fsBtn.addEventListener('click', () => isFs() ? exitFs() : enterFs());
                            document.addEventListener('fullscreenchange',       updateFsIcon);
                            document.addEventListener('webkitfullscreenchange', updateFsIcon);

                            // ── Keyboard shortcuts (desktop only, when detail view is open) ──
                            document.addEventListener('keydown', e => {
                                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
                                if (document.getElementById('detailView')?.classList.contains('hidden')) return;
                                if (e.code === 'Space')          { e.preventDefault(); vid.paused ? vid.play() : vid.pause(); }
                                else if (e.code === 'ArrowRight') vid.currentTime = Math.min(vid.duration || 0, vid.currentTime + 10);
                                else if (e.code === 'ArrowLeft')  vid.currentTime = Math.max(0, vid.currentTime - 10);
                            });

                            setPaused(true);
                        })();
                    </script>

                    <!-- Welcome Popup -->
