                        // ── Franchise Detection ───────────────────────────────────────────────
                        function stripSeasonSuffix(str) {
                            return str
                                .replace(/[-_\s]*(season|part|s)[-_\s]*\d+\s*$/i, '')   // -s2, -season-2, -part-2
                                .replace(/[-_\s]*\d+(?:st|nd|rd|th)?[-_\s]*season\s*$/i, '')  // -2nd-season, -3rd-season
                                .replace(/[-_\s]*\d+\s*$/i, '')                          // trailing number
                                .replace(/[-_]+$/, '')
                                .trim();
                        }

                        function alphaNorm(str) {
                            return str.toLowerCase().replace(/[^a-z0-9]/g, '');
                        }

                        function findFranchiseShows(ch) {
                            if (!ch) return [];

                            const currentCore = stripSeasonSuffix(ch);
                            const currentCoreAlpha = alphaNorm(currentCore);
                            if (currentCoreAlpha.length < 3) return [];

                            const results = [];
                            const seenNames = new Set();

                            for (const name of channelNames) {
                                if (alphaNorm(name) === alphaNorm(ch)) continue;

                                const meta = animeMetadata[name];
                                if (!meta) continue;

                                const chCore      = stripSeasonSuffix(name);
                                const chCoreAlpha = alphaNorm(chCore);

                                const match =
                                    chCoreAlpha === currentCoreAlpha ||
                                    name.startsWith(currentCore + '-') ||
                                    name.startsWith(currentCore + ' ') ||
                                    ch.startsWith(chCore + '-') ||
                                    ch.startsWith(chCore + ' ') ||
                                    (chCoreAlpha.length >= 4 && currentCoreAlpha.startsWith(chCoreAlpha));

                                if (!match) continue;

                                const displayName = meta.name || name;
                                if (seenNames.has(alphaNorm(displayName))) continue;
                                seenNames.add(alphaNorm(displayName));

                                results.push({ channel: name, name: displayName, imageUrl: meta.imageUrl || '' });
                            }
                            return results;
                        }

                        function updateFranchiseSection() {
                            const section  = document.getElementById('franchiseSection');
                            const listEl   = document.getElementById('franchiseList');
                            if (!section || !listEl) return;

                            const related = findFranchiseShows(currentChannel);
                            if (related.length === 0) { section.classList.remove('visible'); return; }

                            listEl.innerHTML = '';

                            const curMeta = animeMetadata[currentChannel];
                            const curDisplayName = curMeta?.name || currentChannel;

                            // Build full list: current + related, dedup by name, then sort by channel name for stable order
                            const allShows = [];
                            if (curMeta) allShows.push({ channel: currentChannel, name: curDisplayName, imageUrl: curMeta.imageUrl || '', isCurrent: true });
                            related.forEach(show => {
                                if (alphaNorm(show.name) !== alphaNorm(curDisplayName)) {
                                    allShows.push({ ...show, isCurrent: false });
                                }
                            });

                            if (allShows.filter(s => !s.isCurrent).length === 0) {
                                section.classList.remove('visible');
                                return;
                            }

                            // Sort by channel name so order never changes when switching seasons
                            allShows.sort((a, b) => a.channel.localeCompare(b.channel));

                            allShows.forEach(show => {
                                const card = document.createElement('div');
                                card.className = 'franchise-card' + (show.isCurrent ? ' active-franchise' : '');
                                card.innerHTML = `<img src="${show.imageUrl || ''}" alt="${show.name}" onerror="this.src='https://via.placeholder.com/36x54?text=?'"><div class="franchise-card-name">${show.name}</div>`;
                                if (!show.isCurrent) {
                                    card.addEventListener('click', () => {
                                        const m = animeMetadata[show.channel];
                                        if (m) showAnimeDetail(m, show.channel);
                                        else loadChannel(show.channel, show.name);
                                    });
                                }
                                listEl.appendChild(card);
                            });

                            section.classList.add('visible');
                        }

