                        let fadeObserver;
                        if ('IntersectionObserver' in window) {
                            fadeObserver = new IntersectionObserver((entries) => {
                                entries.forEach((entry, i) => {
                                    if (entry.isIntersecting) {
                                        const card = entry.target;
                                        const img = card.querySelector('img');
                                        if (img && img.loading === 'lazy') img.loading = 'eager';
                                        const doFade = () => {
                                            setTimeout(() => {
                                                card.classList.add('fade-in');
                                            }, i * 60);
                                        };
                                        if (img && !img.complete) {
                                            img.addEventListener('load', doFade, { once: true });
                                            img.addEventListener('error', doFade, { once: true });
                                        } else {
                                            doFade();
                                        }
                                        fadeObserver.unobserve(card);
                                    }
                                });
                            }, { threshold: 0.05, rootMargin: '100px 0px' });

                            document.querySelectorAll('.home-grid .anime-card').forEach(card => {
                                fadeObserver.observe(card);
                            });
                        } else {
                            document.body.classList.add('no-observer');
                            document.querySelectorAll('.home-grid .anime-card').forEach(card => {
                                card.classList.add('fade-in');
