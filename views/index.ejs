                    </style>

                    <div id="welcomeOverlay" class="hidden">
                        <div id="welcomePopup">
                            <div id="welcomePopupImgWrap">
                                <img id="welcomePopupImg"
                                     src="https://raw.githubusercontent.com/darrk5200/images/refs/heads/main/itsukime.png"
                                     alt="Itsukime">
                            </div>
                            <div id="welcomePopupBody">
                                <h2 id="welcomePopupTitle">Welcome to Itsukime</h2>
                                <p id="welcomePopupDesc">HD Streaming, Adless Experience, Seasonal Anime & Limitless screentime!</p>
